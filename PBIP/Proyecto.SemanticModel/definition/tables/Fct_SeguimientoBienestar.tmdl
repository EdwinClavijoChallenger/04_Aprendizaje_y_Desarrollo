	column ObservacionEjecucion
		dataType: string
		lineageTag: ee2dd778-da38-4e35-a893-208f3b310cf0
		summarizeBy: none
		sourceColumn: [ObservacionEjecucion]

		annotation SummarizationSetBy = Automatic

	partition Fct_SeguimientoBienestar = calculated
		mode: import
		source =
				VAR _Planeacion =
				    SELECTCOLUMNS(
				        'Stg_Bienestar_Planeacion',
				        "DimensionBienestar_Key", UPPER(TRIM(COALESCE('Stg_Bienestar_Planeacion'[DIMENSION], ""))),
				        "ActividadBienestar_Key", UPPER(TRIM(COALESCE('Stg_Bienestar_Planeacion'[DIMENSION], ""))) & "|" & UPPER(TRIM(COALESCE('Stg_Bienestar_Planeacion'[COMPONENTES], ""))),
				        "Anio", 'Stg_Bienestar_Planeacion'[Anio],
				        "NumeroMes", 'Stg_Bienestar_Planeacion'[NumeroMes],
				        "Mes", 'Stg_Bienestar_Planeacion'[Mes],
				        "PlaneadoOriginal", IF(UPPER(TRIM(COALESCE('Stg_Bienestar_Planeacion'[Planeado], ""))) = "X", 1, 0),
				        "ObservacionPlaneacion", TRIM(COALESCE('Stg_Bienestar_Planeacion'[OBSERVACION], ""))
				    )
				VAR _Ejecucion =
				    SELECTCOLUMNS(
				        'Stg_Bienestar_Ejecucion',
				        "DimensionBienestar_Key", UPPER(TRIM(COALESCE('Stg_Bienestar_Ejecucion'[DIMENSION], ""))),
				        "ActividadBienestar_Key", UPPER(TRIM(COALESCE('Stg_Bienestar_Ejecucion'[DIMENSION], ""))) & "|" & UPPER(TRIM(COALESCE('Stg_Bienestar_Ejecucion'[COMPONENTES], ""))),
				        "Anio", 'Stg_Bienestar_Ejecucion'[Anio],
				        "NumeroMes", 'Stg_Bienestar_Ejecucion'[NumeroMes],
				        "Mes", 'Stg_Bienestar_Ejecucion'[Mes],
				        "PlaneadoEjecucion", IF(UPPER(TRIM(COALESCE('Stg_Bienestar_Ejecucion'[Planeado], ""))) = "X", 1, 0),
				        "EjecutadoReal", IF(UPPER(TRIM(COALESCE('Stg_Bienestar_Ejecucion'[Ejecutado], ""))) = "OK", 1, 0),
				        "ObservacionEjecucion", TRIM(COALESCE('Stg_Bienestar_Ejecucion'[OBSERVACION], ""))
				    )
				VAR _Actividades =
				    FILTER(
				        DISTINCT(
				            UNION(
				                SELECTCOLUMNS(
				                    _Planeacion,
				                    "DimensionBienestar_Key", [DimensionBienestar_Key],
				                    "ActividadBienestar_Key", [ActividadBienestar_Key]
				                ),
				                SELECTCOLUMNS(
				                    _Ejecucion,
				                    "DimensionBienestar_Key", [DimensionBienestar_Key],
				                    "ActividadBienestar_Key", [ActividadBienestar_Key]
				                )
				            )
				        ),
				        NOT ISBLANK([ActividadBienestar_Key]) && [ActividadBienestar_Key] <> "|"
				    )
				VAR _Meses =
				    DATATABLE(
				        "Anio", INTEGER,
				        "NumeroMes", INTEGER,
				        "Mes", STRING,
				        {
				            { 2026, 1, "Enero" },
				            { 2026, 2, "Febrero" },
				            { 2026, 3, "Marzo" },
				            { 2026, 4, "Abril" },
				            { 2026, 5, "Mayo" },
				            { 2026, 6, "Junio" },
				            { 2026, 7, "Julio" },
				            { 2026, 8, "Agosto" },
				            { 2026, 9, "Septiembre" },
				            { 2026, 10, "Octubre" },
				            { 2026, 11, "Noviembre" },
				            { 2026, 12, "Diciembre" }
				        }
				    )
				VAR _Keys =
				    CROSSJOIN(
				        _Actividades,
				        _Meses
				    )
				VAR _Base =
				    ADDCOLUMNS(
				        _Keys,
				        "SeguimientoBienestar_Key", [ActividadBienestar_Key] & "|" & FORMAT([Anio], "0000") & "-" & FORMAT([NumeroMes], "00"),
				        "FechaPeriodo", DATE([Anio], [NumeroMes], 1),
				        "AnioMes", FORMAT(DATE([Anio], [NumeroMes], 1), "YYYY-MM"),
				        "AnioMesOrden", [Anio] * 100 + [NumeroMes],
				        "PlaneadoOriginal",
				            VAR _DimensionKey = [DimensionBienestar_Key]
				            VAR _ActividadKey = [ActividadBienestar_Key]
				            VAR _Anio = [Anio]
				            VAR _NumeroMes = [NumeroMes]
				            RETURN
				                COALESCE(
				                    MAXX(
				                        FILTER(
				                            _Planeacion,
				                            [DimensionBienestar_Key] = _DimensionKey &&
				                            [ActividadBienestar_Key] = _ActividadKey &&
				                            [Anio] = _Anio &&
				                            [NumeroMes] = _NumeroMes
				                        ),
				                        [PlaneadoOriginal]
				                    ),
				                    0
				                ),
				        "PlaneadoEjecucion",
				            VAR _DimensionKey = [DimensionBienestar_Key]
				            VAR _ActividadKey = [ActividadBienestar_Key]
				            VAR _Anio = [Anio]
				            VAR _NumeroMes = [NumeroMes]
				            RETURN
				                COALESCE(
				                    MAXX(
				                        FILTER(
				                            _Ejecucion,
				                            [DimensionBienestar_Key] = _DimensionKey &&
				                            [ActividadBienestar_Key] = _ActividadKey &&
				                            [Anio] = _Anio &&
				                            [NumeroMes] = _NumeroMes
				                        ),
				                        [PlaneadoEjecucion]
				                    ),
				                    0
				                ),
				        "EjecutadoReal",
				            VAR _DimensionKey = [DimensionBienestar_Key]
				            VAR _ActividadKey = [ActividadBienestar_Key]
				            VAR _Anio = [Anio]
				            VAR _NumeroMes = [NumeroMes]
				            RETURN
				                COALESCE(
				                    MAXX(
				                        FILTER(
				                            _Ejecucion,
				                            [DimensionBienestar_Key] = _DimensionKey &&
				                            [ActividadBienestar_Key] = _ActividadKey &&
				                            [Anio] = _Anio &&
				                            [NumeroMes] = _NumeroMes
				                        ),
				                        [EjecutadoReal]
				                    ),
				                    0
				                ),
				        "ObservacionPlaneacion",
				            VAR _DimensionKey = [DimensionBienestar_Key]
				            VAR _ActividadKey = [ActividadBienestar_Key]
				            VAR _Anio = [Anio]
				            VAR _NumeroMes = [NumeroMes]
				            RETURN
				                CONCATENATEX(
				                    DISTINCT(
				                        SELECTCOLUMNS(
				                            FILTER(
				                                _Planeacion,
				                                [DimensionBienestar_Key] = _DimensionKey &&
				                                [ActividadBienestar_Key] = _ActividadKey &&
				                                [Anio] = _Anio &&
				                                [NumeroMes] = _NumeroMes
				                            ),
				                            "Observacion", [ObservacionPlaneacion]
				                        )
				                    ),
				                    [Observacion],
				                    " | "
				                ),
				        "ObservacionEjecucion",
				            VAR _DimensionKey = [DimensionBienestar_Key]
				            VAR _ActividadKey = [ActividadBienestar_Key]
				            VAR _Anio = [Anio]
				            VAR _NumeroMes = [NumeroMes]
				            RETURN
				                CONCATENATEX(
				                    DISTINCT(
				                        SELECTCOLUMNS(
				                            FILTER(
				                                _Ejecucion,
				                                [DimensionBienestar_Key] = _DimensionKey &&
				                                [ActividadBienestar_Key] = _ActividadKey &&
				                                [Anio] = _Anio &&
				                                [NumeroMes] = _NumeroMes
				                            ),
				                            "Observacion", [ObservacionEjecucion]
				                        )
				                    ),
				                    [Observacion],
				                    " | "
				                )
				    )
				VAR _PeriodoCorte =
				    MAXX(
				        FILTER(
				            _Base,
				            [EjecutadoReal] = 1
				        ),
				        [FechaPeriodo]
				    )
				RETURN
				    ADDCOLUMNS(
				        _Base,
				        "DiferenciaProgramacion", [PlaneadoEjecucion] - [PlaneadoOriginal],
				        "EstadoProgramacion",
				            SWITCH(
				                TRUE(),
				                [PlaneadoOriginal] = 1 && [PlaneadoEjecucion] = 1, "Sin diferencia",
				                [PlaneadoOriginal] = 1 && [PlaneadoEjecucion] = 0, "Retirado de ejecucion",
				                [PlaneadoOriginal] = 0 && [PlaneadoEjecucion] = 1, "Agregado en ejecucion",
				                "Sin programacion"
				            ),
				        "EstadoAlCorte",
				            VAR _PlanVigente = [PlaneadoEjecucion] = 1
				            VAR _RetiradoEjecucion = [PlaneadoOriginal] = 1 && [PlaneadoEjecucion] = 0 && [EjecutadoReal] = 0
				            RETURN
				                SWITCH(
				                    TRUE(),
				                    [PlaneadoOriginal] = 0 && [EjecutadoReal] = 1, "Ejecutado no planeado",
				                    [EjecutadoReal] = 1, "Ejecutado",
				                    _RetiradoEjecucion, "Retirado de ejecucion",
				                    NOT _PlanVigente, "No programado",
				                    ISBLANK(_PeriodoCorte) && _PlanVigente, "Pendiente sin corte",
				                    _PlanVigente && [FechaPeriodo] < _PeriodoCorte, "Pendiente vencido",
				                    _PlanVigente && [FechaPeriodo] = _PeriodoCorte, "Pendiente en curso",
				                    _PlanVigente && [FechaPeriodo] > _PeriodoCorte, "Pendiente futuro",
				                    "No programado"
				                )
				    )

