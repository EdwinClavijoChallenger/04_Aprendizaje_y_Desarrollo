table Dim_Anio_Desempeno
	lineageTag: 193ab542-5a9a-45b1-a781-db606ae7c377

	column Anio
		dataType: int64
		formatString: 0
		lineageTag: e77c7fd4-9193-4e13-be9d-2d8486430060
		summarizeBy: none
		sourceColumn: [Anio]

	partition Dim_Anio_Desempeno = calculated
		mode: import
		source =
				DISTINCT(
					SELECTCOLUMNS(
						FILTER(
							'Fct_Desempeno_2025',
							NOT ISBLANK('Fct_Desempeno_2025'[Fecha de Proceso])
						),
						"Anio", YEAR('Fct_Desempeno_2025'[Fecha de Proceso])
					)
				)
