table Dim_Anio_Desempeno
	lineageTag: 193ab542-5a9a-45b1-a781-db606ae7c377

	column Anio
		dataType: int64
		formatString: 0
		lineageTag: e77c7fd4-9193-4e13-be9d-2d8486430060
		summarizeBy: none
		sourceColumn: [Anio]

	partition Dim_Anio_Desempeno = calculated
		mode: import
		source =
				VAR _AniosDesempeno =
					SELECTCOLUMNS(
						FILTER(
							'Fct_Desempeno_2025',
							NOT ISBLANK('Fct_Desempeno_2025'[Anio])
						),
						"Anio", 'Fct_Desempeno_2025'[Anio]
					)
				VAR _AniosCompetencias =
					SELECTCOLUMNS(
						FILTER(
							'Fct_Competencias_2025',
							NOT ISBLANK('Fct_Competencias_2025'[Anio])
						),
						"Anio", 'Fct_Competencias_2025'[Anio]
					)
				VAR _AniosPoblacion =
					SELECTCOLUMNS(
						FILTER(
							'Fct_Poblacion_Indicadores_2025',
							NOT ISBLANK('Fct_Poblacion_Indicadores_2025'[Anio])
						),
						"Anio", 'Fct_Poblacion_Indicadores_2025'[Anio]
					)
				RETURN
					DISTINCT(
						UNION(
							_AniosDesempeno,
							_AniosCompetencias,
							_AniosPoblacion
						)
					)

