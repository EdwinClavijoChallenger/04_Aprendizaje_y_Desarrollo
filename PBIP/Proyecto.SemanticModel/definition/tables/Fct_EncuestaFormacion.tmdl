				    Origen = Excel.Workbook(Web.Contents("https://lemcosas.sharepoint.com/sites/TalentoHumanoGrupoLemco/Documentos%20compartidos/5.%20People%20analytics/04_Aprendizaje_y_Desarrollo/Data/%C2%A1Queremos%20conocer%20tu%20opini%C3%B3n%20sobre%20nuestra%20formaci%C3%B3n!.xlsx"), null, true),
				    OfficeForms.Table_Table = Origen{[Item="OfficeForms.Table",Kind="Table"]}[Data],
				    #"Tipo cambiado" = Table.TransformColumnTypes(OfficeForms.Table_Table,{{"Id", Int64.Type}, {"Hora de inicio", type datetime}, {"Hora de finalización", type datetime}, {"Correo electrónico", type text}, {"Nombre", type any}, {"¡Cuéntanos tu percepción de la formación!", type text}, {"Indícanos de qué empresa haces parte", type text}, {"¿Qué tan satisfecho te encuentras con el dominio del tema por parte del facilitador?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con la habilidad para comunicarse y transmitir ideas por parte del facilitador?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con las actividades o ejercicios por parte del facilitador?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con el uso de ayudas didácticas por parte del facilitador?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con la resolución de dudas u observaciones del facilitador?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con el cumplimiento del programa propuesto?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con el espacio, logística y ambiente de la formación?", Int64.Type}, {"¿Qué tan oportuna fue la información respecto a fechas, horarios y lugar?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con el logro de los objetivos propuestos?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con la contribución del programa para tu desarrollo personal y/o profesional?", Int64.Type}, {"¿Qué tan satisfecho te encuentras con el acompañamiento de la Universidad Challenger en tu desarrollo personal y/o profesional?", Int64.Type}, {"En general, ¿Qué tan satisfecho te encuentras con la formación recibida?", Int64.Type}, {"¡Cuéntanos! #(lf)¿Qué fue lo que más valoraste y qué podríamos mejorar?", type text}})
				in
				    #"Tipo cambiado"

	annotation PBI_NavigationStepName = Navegación

