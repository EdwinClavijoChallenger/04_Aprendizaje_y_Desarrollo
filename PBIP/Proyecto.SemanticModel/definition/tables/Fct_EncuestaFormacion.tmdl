	column Fecha_Encuesta = VAR _d = 'Fct_EncuestaFormacion'[Hora de inicio] RETURN IF(ISBLANK(_d), BLANK(), DATE(YEAR(_d), MONTH(_d), DAY(_d)))
		dataType: dateTime
		isHidden
		formatString: Short Date
		lineageTag: 7fcb1419-0db3-4cb2-9ddf-ef3676f617b9

	column TemaFormacion_Key =
			VAR _t0 = UPPER(TRIM(SUBSTITUTE(COALESCE('Fct_EncuestaFormacion'[¡Cuéntanos tu percepción de la formación!], ""), UNICHAR(160), " ")))
			VAR _t1 = SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(_t0, "Á", "A"), "É", "E"), "Í", "I"), "Ó", "O"), "Ú", "U"), "Ñ", "N")
			VAR _t2 = SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(_t1, ".", ""), "  ", " "), "  ", " ")
			RETURN IF(_t2 = "", "", _t2)
		dataType: string
		isHidden
		lineageTag: 6a9abaa8-24f2-44dd-935b-0e8299b8c7fd

	column Empresa_Key =
			VAR _t0 = UPPER(TRIM(SUBSTITUTE(COALESCE('Fct_EncuestaFormacion'[Indícanos de qué empresa haces parte], ""), UNICHAR(160), " ")))
			VAR _t1 = SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(_t0, "Á", "A"), "É", "E"), "Í", "I"), "Ó", "O"), "Ú", "U"), "Ñ", "N")
			VAR _t2 = SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(_t1, ".", ""), "  ", " "), "  ", " ")
			RETURN
			    SWITCH(
			        TRUE(),
			        _t2 = "", "SIN_EMPRESA",
			        _t2 IN { "CHALLENGER SAS", "CHALLENGER S A S" }, "CHALLENGER SAS",
			        _t2 IN { "LEMCO SAS", "LEMCO S A S" }, "LEMCO SAS",
			        CONTAINSSTRING(_t2, "FUNDACION CHALLENGER"), "FUNDACION CHALLENGER",
			        _t2
			    )
		dataType: string
		isHidden
		lineageTag: 47c0aeb0-2755-4238-992a-9f85980330e5

	partition Fct_EncuestaFormacion = m
		mode: import
		source =
