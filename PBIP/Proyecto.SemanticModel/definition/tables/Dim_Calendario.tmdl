	column Trimestre = "T" & FORMAT(QUARTER('Dim_Calendario'[Date]), "0")
		dataType: string
		lineageTag: 9d7b6bdb-649a-407f-8bc3-e98a075c8b0b

	partition Dim_Calendario = calculated
		mode: import
		source =
				
				VAR MinDate = DATE(2022, 1, 1)
				VAR MaxDate = DATE(2026, 12, 31)
				RETURN
				ADDCOLUMNS(
				    FILTER(
				        CALENDAR(MinDate, MaxDate),
				        [Date] <= MaxDate
				    ),
				    "Año", YEAR([Date]),
				    "AñoMes", FORMAT([Date], "YYYY-MM"),
				    "Numero Mes", MONTH([Date]),
				    "Mes Abreviado", FORMAT([Date], "mmm"),
				    "Numero Semana", WEEKNUM([Date], 21),
				    "Numero Dia", DAY([Date]),
				    "Numero Dia de la Semana", WEEKDAY([Date], 2),
				    "Dia Semana", FORMAT([Date], "dddd"),
				    "Dia Abreviado", LEFT(FORMAT([Date], "dddd"), 3),
				    "Día del año", DATEDIFF(DATE(YEAR([Date]), 1, 1), [Date], DAY) + 1
				)

	annotation PBI_Id = deb9005d004f4dc1ac404d84ce54fce6

