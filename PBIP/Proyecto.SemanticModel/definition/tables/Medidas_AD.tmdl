	measure 'NineBox Competencias Score' = AVERAGE('Fct_Competencias_2025'[Puntaje Obtenido])
		formatString: 0.00
		displayFolder: 14 Nine Box
		lineageTag: 4aa66576-b6e4-4cf8-bff2-df3e7ce42a94

	measure 'NineBox Banda Desempeno' =
			VAR _Score = [NineBox Desempeno Score]
			RETURN
				SWITCH(
					TRUE(),
					ISBLANK(_Score), BLANK(),
					_Score <= 50, "Bajo",
					_Score <= 70, "Medio",
					_Score >= 71, "Alto",
					BLANK()
				)
		displayFolder: 14 Nine Box
		lineageTag: e0567d4e-4354-4182-b85e-f67460da2a22

	measure 'NineBox Banda Competencias' =
			VAR _Score = [NineBox Competencias Score]
			RETURN
				SWITCH(
					TRUE(),
					ISBLANK(_Score), BLANK(),
					_Score <= 50, "Bajo",
					_Score <= 70, "Medio",
					_Score >= 71, "Alto",
					BLANK()
				)
		displayFolder: 14 Nine Box
		lineageTag: 8e501ad5-0b9d-4e2c-a3ee-e269d276bb2d

	measure 'NineBox Cuadrante' =
			VAR _BandaDesempeno = [NineBox Banda Desempeno]
			VAR _BandaCompetencias = [NineBox Banda Competencias]
			RETURN
				IF(
					ISBLANK(_BandaDesempeno) || ISBLANK(_BandaCompetencias),
					BLANK(),
					_BandaDesempeno & "-" & _BandaCompetencias
				)
		displayFolder: 14 Nine Box
		lineageTag: cfa4ac19-4eb1-4d9e-a9ff-078b60ae1661

	measure 'NineBox Categoria Ejecutiva' =
			SWITCH(
				[NineBox Cuadrante],
				"Alto-Alto", "Alto Potencial",
				"Alto-Medio", "Alto Potencial",
				"Medio-Medio", "Talento Sólido",
				"Medio-Alto", "Talento Sólido",
				"Bajo-Alto", "Talento Sólido",
				"Alto-Bajo", "Desarrollo Requerido",
				"Medio-Bajo", "Desarrollo Requerido",
				"Bajo-Bajo", "Riesgo",
				"Bajo-Medio", "Riesgo",
				BLANK()
			)
		displayFolder: 14 Nine Box
		lineageTag: 84444867-3181-4409-863e-2b55915d946b

	measure 'NineBox Colaboradores Evaluables' =
			VAR _Base =
				FILTER(
					CALCULATETABLE(
						VALUES('Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]),
						KEEPFILTERS('Fct_Poblacion_Indicadores_2025'[INDICADOR ACTIVIDAD] = "ACTIVO")
					),
					NOT ISBLANK('Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key])
				)
			VAR _Scored =
				ADDCOLUMNS(
					_Base,
					"__Desempeno",
						VAR _Key = 'Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]
						RETURN
							CALCULATE(
								AVERAGE('Fct_Desempeno_2025'[Calificación Final]),
								'Fct_Desempeno_2025'[ColaboradorDesempeno_Key] = _Key
							),
					"__Competencias",
						VAR _Key = 'Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]
						RETURN
							CALCULATE(
								AVERAGE('Fct_Competencias_2025'[Puntaje Obtenido]),
								'Fct_Competencias_2025'[ColaboradorDesempeno_Key] = _Key
							)
				)
			VAR _Bandas =
				ADDCOLUMNS(
					_Scored,
					"__BandaDesempeno",
						VAR _Score = [__Desempeno]
						RETURN
							SWITCH(
								TRUE(),
								ISBLANK(_Score), BLANK(),
								_Score <= 50, "Bajo",
								_Score <= 70, "Medio",
								_Score >= 71, "Alto",
								BLANK()
							),
					"__BandaCompetencias",
						VAR _Score = [__Competencias]
						RETURN
							SWITCH(
								TRUE(),
								ISBLANK(_Score), BLANK(),
								_Score <= 50, "Bajo",
								_Score <= 70, "Medio",
								_Score >= 71, "Alto",
								BLANK()
							)
				)
			RETURN
				COUNTROWS(
					FILTER(
						_Bandas,
						NOT ISBLANK([__BandaDesempeno]) &&
						NOT ISBLANK([__BandaCompetencias])
					)
				)
		formatString: #,0
		displayFolder: 14 Nine Box
		lineageTag: 767e3ff6-dd91-4966-86db-fc613c070a75

	measure 'NineBox Colaboradores por Cuadrante' =
			VAR _TargetDesempeno = SELECTEDVALUE('Dim_NineBox_Cuadrante'[Banda_Desempeno])
			VAR _TargetCompetencias = SELECTEDVALUE('Dim_NineBox_Cuadrante'[Banda_Competencias])
			VAR _TargetCategoria = SELECTEDVALUE('Dim_NineBox_Cuadrante'[Categoria_Ejecutiva])
			VAR _Base =
				FILTER(
					CALCULATETABLE(
						VALUES('Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]),
						KEEPFILTERS('Fct_Poblacion_Indicadores_2025'[INDICADOR ACTIVIDAD] = "ACTIVO")
					),
					NOT ISBLANK('Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key])
				)
			VAR _Scored =
				ADDCOLUMNS(
					_Base,
					"__Desempeno",
						VAR _Key = 'Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]
						RETURN
							CALCULATE(
								AVERAGE('Fct_Desempeno_2025'[Calificación Final]),
								'Fct_Desempeno_2025'[ColaboradorDesempeno_Key] = _Key
							),
					"__Competencias",
						VAR _Key = 'Fct_Poblacion_Indicadores_2025'[ColaboradorDesempeno_Key]
						RETURN
							CALCULATE(
								AVERAGE('Fct_Competencias_2025'[Puntaje Obtenido]),
								'Fct_Competencias_2025'[ColaboradorDesempeno_Key] = _Key
							)
				)
			VAR _Bandas =
				ADDCOLUMNS(
					_Scored,
					"__BandaDesempeno",
						VAR _Score = [__Desempeno]
						RETURN
							SWITCH(
								TRUE(),
								ISBLANK(_Score), BLANK(),
								_Score <= 50, "Bajo",
								_Score <= 70, "Medio",
								_Score >= 71, "Alto",
								BLANK()
							),
					"__BandaCompetencias",
						VAR _Score = [__Competencias]
						RETURN
							SWITCH(
								TRUE(),
								ISBLANK(_Score), BLANK(),
								_Score <= 50, "Bajo",
								_Score <= 70, "Medio",
								_Score >= 71, "Alto",
								BLANK()
							)
				)
			VAR _Categoria =
				ADDCOLUMNS(
					_Bandas,
					"__Categoria",
						VAR _Cuadrante = [__BandaDesempeno] & "-" & [__BandaCompetencias]
						RETURN
							SWITCH(
								_Cuadrante,
								"Alto-Alto", "Alto Potencial",
								"Alto-Medio", "Alto Potencial",
								"Medio-Medio", "Talento Sólido",
								"Medio-Alto", "Talento Sólido",
								"Bajo-Alto", "Talento Sólido",
								"Alto-Bajo", "Desarrollo Requerido",
								"Medio-Bajo", "Desarrollo Requerido",
								"Bajo-Bajo", "Riesgo",
								"Bajo-Medio", "Riesgo",
								BLANK()
							)
				)
			RETURN
				COUNTROWS(
					FILTER(
						_Categoria,
						NOT ISBLANK([__BandaDesempeno]) &&
						NOT ISBLANK([__BandaCompetencias]) &&
						(ISBLANK(_TargetDesempeno) || [__BandaDesempeno] = _TargetDesempeno) &&
						(ISBLANK(_TargetCompetencias) || [__BandaCompetencias] = _TargetCompetencias) &&
						(ISBLANK(_TargetCategoria) || [__Categoria] = _TargetCategoria)
					)
				)
		formatString: #,0
		displayFolder: 14 Nine Box
		lineageTag: e6a80cb3-b3cf-4817-8170-baf02af18e12

