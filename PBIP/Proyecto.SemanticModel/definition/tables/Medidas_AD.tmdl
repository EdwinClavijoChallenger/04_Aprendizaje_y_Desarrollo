		displayFolder: 04 Induccion UC
		lineageTag: f65cb718-1c4d-4332-9ad3-fc3614da6098

	measure 'PDI Total' = COUNTROWS('Fct_Seguimiento_PDI')
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 5a0f5c43-7197-4b55-bdb5-78b021eb2a9e

	measure 'PDI Colaboradores Unicos' = DISTINCTCOUNT('Fct_Seguimiento_PDI'[Identificacion_Colaborador])
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: b3fb1782-2f58-46f8-9745-391f13483a56

	measure 'PDI Motivos Distintos' = DISTINCTCOUNT('Dim_MotivoPDI'[MotivoPDI_Key])
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 7ba1e69c-e498-4147-b910-d15c197deac1

	measure 'PDI Jefes Con PDI' = DISTINCTCOUNT('Fct_Seguimiento_PDI'[Jefe_Inmediato])
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: db9526bf-b4fd-4244-a819-65b4d9b6fcc0

	measure 'PDI Cargos Con PDI' = DISTINCTCOUNT('Fct_Seguimiento_PDI'[Cargo])
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 6c748cfe-5f00-4a07-8812-22f9772fc8ee

	measure 'PDI Avance Promedio' =
			VAR _Avance = AVERAGE('Fct_Seguimiento_PDI'[Avance_PDI])
			RETURN IF(_Avance > 1, DIVIDE(_Avance, 100), _Avance)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: d3c5fd73-5514-452a-9f17-7d6b4acc146f

	measure 'PDI Finalizados' =
			CALCULATE(
			    [PDI Total],
			    'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO" }
			)
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: f8448f24-385d-40ac-bd45-aaac5564f3ac

	measure 'PDI Activos' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        NOT (
			            'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			        )
			    )
			)
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 950fa908-217a-41c9-9faa-4e9652af48b9

	measure 'PDI Pendientes' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "PENDIENTE", "EN PROCESO", "ACTIVO", "" }
			            || ISBLANK('Fct_Seguimiento_PDI'[EstadoPDI_Key])
			    )
			)
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 4425b154-c390-4b36-b8e2-7db2c812e5fd

	measure 'PDI Porcentaje Activos' = DIVIDE([PDI Activos], [PDI Total], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: 15cc444a-841d-4c49-b4c0-7c3cf976c4f2

	measure 'PDI Porcentaje Por Estado' = DIVIDE([PDI Total], CALCULATE([PDI Total], ALLSELECTED('Dim_EstadoPDI'[Estado_PDI])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: 707e9860-ed38-4dc1-a671-8117f3762692

	measure 'PDI Porcentaje Por Motivo' = DIVIDE([PDI Total], CALCULATE([PDI Total], ALLSELECTED('Dim_MotivoPDI'[Motivo_PDI])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: ebfc3785-f433-4bea-818b-bb45d4c0cb4b

	measure 'PDI Avance Cero' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        COALESCE('Fct_Seguimiento_PDI'[Avance_PDI], 0) = 0
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 086d71ab-3c67-4838-b895-5970f0cb7e0c

	measure 'PDI Bajo Avance' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        VAR _Avance = IF('Fct_Seguimiento_PDI'[Avance_PDI] > 1, DIVIDE('Fct_Seguimiento_PDI'[Avance_PDI], 100), 'Fct_Seguimiento_PDI'[Avance_PDI])
			        RETURN _Avance > 0 && _Avance < 0.4
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 9e73a3c1-e8bd-42f3-97d3-cd63918c668c

	measure 'PDI Vencidos' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] < TODAY()
			            && NOT (
			                'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			            )
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 310e0db2-f0d1-4d70-a8b7-5b8147cfcc09

	measure 'PDI Proximos A Vencer' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] >= TODAY()
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] <= TODAY() + 30
			            && NOT (
			                'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			            )
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: e7d2735e-d44e-4d17-8a64-49ad6772b7ab

	measure 'PDI Acompanamientos Programados' =
			CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_1] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_2] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_3] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 2930cd49-066d-46c1-8af5-c7b11eea1c81

	measure 'PDI Acompanamientos Ejecutados' =
			CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_1] IN { "E", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_2] IN { "E", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_3] IN { "E", "EJECUTADO" })
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 7b38b540-17ee-4260-8b71-af862d8ebc4f

	measure 'PDI Cumplimiento Acompanamientos' = DIVIDE([PDI Acompanamientos Ejecutados], [PDI Acompanamientos Programados], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: c052eeff-33ed-4762-b7b8-09026516a598

	measure 'PDI Alertas Criticas' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        VAR _Avance = IF('Fct_Seguimiento_PDI'[Avance_PDI] > 1, DIVIDE('Fct_Seguimiento_PDI'[Avance_PDI], 100), 'Fct_Seguimiento_PDI'[Avance_PDI])
			        VAR _Vencido =
			            NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			                && 'Fct_Seguimiento_PDI'[Fecha_Fin] < TODAY()
			                && NOT (
			                    'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			                )
			        RETURN COALESCE(_Avance, 0) = 0 || (_Avance > 0 && _Avance < 0.4) || _Vencido
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 5acc123f-755e-4c25-85f0-8f26d30a6718

	measure 'PDI Ranking Area Total' = RANKX(ALLSELECTED('Dim_Area'[Area]), [PDI Total], , DESC, Dense)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: b35f3a01-d64d-475a-92b0-984816763f7b

	measure 'PDI Ranking Jefe Bajo Avance' = RANKX(ALLSELECTED('Fct_Seguimiento_PDI'[Jefe_Inmediato]), [PDI Bajo Avance], , DESC, Dense)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 4d23f49d-100d-4fcd-9bc6-af3e454183f7

	measure 'KPI Indice Desarrollo' =
			VAR _SinVencidos = 1 - DIVIDE([PDI Vencidos], [PDI Total], 0)
			VAR _Base =
			    {
			        [PDI Avance Promedio],
			        [PDI Cumplimiento Acompanamientos],
			        _SinVencidos
			    }
			RETURN
			    AVERAGEX(FILTER(_Base, NOT ISBLANK([Value])), [Value])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 00 KPIs Gerenciales
		lineageTag: e1b75bcf-3df0-489e-9ccb-f0d3d97846fb

	measure 'HTML Inicio Corporativo Propuesta 1' =
			VAR _FA = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cob = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Sat = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Onb = IF(ISBLANK([Induccion Porcentaje Cumplimiento]), "-", FORMAT([Induccion Porcentaje Cumplimiento], "0.0%"))
			VAR _Ent = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _IApz = IF(ISBLANK([KPI Indice Aprendizaje]), "-", FORMAT([KPI Indice Aprendizaje], "0.0%"))
			VAR _PDIAct = IF(ISBLANK([PDI Activos]), "-", FORMAT([PDI Activos], "#,0"))
			VAR _PDIAvz = IF(ISBLANK([PDI Avance Promedio]), "-", FORMAT([PDI Avance Promedio], "0.0%"))
			VAR _PDIAlt = IF(ISBLANK([PDI Alertas Criticas]), "-", FORMAT([PDI Alertas Criticas], "#,0"))
			VAR _Acomp = IF(ISBLANK([PDI Cumplimiento Acompanamientos]), "-", FORMAT([PDI Cumplimiento Acompanamientos], "0.0%"))
			VAR _IDes = IF(ISBLANK([KPI Indice Desarrollo]), "-", FORMAT([KPI Indice Desarrollo], "0.0%"))
			VAR _CtaTexto =
			    SWITCH(
			        _FA,
			        "Aprendizaje", "Ver tablero completo de Aprendizaje",
			        "Desarrollo", "Ver resumen ejecutivo de Desarrollo",
			        "Bienestar y Clima", "Ver Entrevista de Retiro",
			        "Desempeno", "Ver frente Desempe&ntilde;o",
			        "Ver tablero completo de Aprendizaje"
			    )
			VAR _LeftContent =
			    IF(_FA = "Aprendizaje",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Aprendizaje</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>Formaci&oacute;n, cobertura, satisfacci&oacute;n, onboarding y entrenamiento inicial.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Horas formaci&oacute;n</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Horas & "</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Cobertura</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Cob & "</div></div>" &
			        "<div style='border-left:4px solid #1A3059;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Satisfacci&oacute;n</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Sat & "</div></div>" &
			        "<div style='border-left:4px solid #0B1C35;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Onboarding</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Onb & "</div></div>" &
			        "</div><div style='display:flex;gap:10px;margin-top:11px;'>" &
			        "<div style='flex:1;background:#0B1C35;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Entrenamiento neto</div><div style='font-size:21px;font-weight:800;'>" & _Ent & "</div></div>" &
			        "<div style='flex:1;background:#1B487F;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Indice Aprendizaje</div><div style='font-size:21px;font-weight:800;'>" & _IApz & "</div></div>" &
			        "</div><div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>",
			    IF(_FA = "Desarrollo",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Desarrollo</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>Planes de Desarrollo Individual, avance, acompa&ntilde;amientos y alertas.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>PDI activos</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _PDIAct & "</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Avance promedio</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _PDIAvz & "</div></div>" &
			        "<div style='border-left:4px solid #1A3059;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Acompa&ntilde;amientos</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Acomp & "</div></div>" &
			        "<div style='border-left:4px solid #E85D24;background:#FFF4F1;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#9D3B2A;'>Alertas criticas</div><div style='font-size:25px;font-weight:800;color:#E85D24;'>" & _PDIAlt & "</div></div>" &
			        "</div><div style='display:flex;gap:10px;margin-top:11px;'>" &
			        "<div style='flex:1;background:#0B1C35;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Indice Desarrollo</div><div style='font-size:21px;font-weight:800;'>" & _IDes & "</div></div>" &
			        "<div style='flex:1;background:#1B487F;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Avance PDI</div><div style='font-size:21px;font-weight:800;'>" & _PDIAvz & "</div></div>" &
			        "</div><div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>",
			        "<div style='font-size:11px;color:#1B487F;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>" & IF(_FA = "Desempeno", "Proxima fase", "Frente iniciado") & "</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#1A3059;'>" & IF(_FA = "Desempeno", "Desempe&ntilde;o", "Bienestar y Clima") & "</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>" & IF(_FA = "Desempeno", "Evaluaci&oacute;n de desempe&ntilde;o, metas y seguimiento gerencial.", "Entrevista de Retiro activa con roadmap de clima laboral, eNPS y plan de bienestar.") & "</div>" &
			        "<div style='margin-top:32px;background:#EBF0F8;border-radius:14px;padding:30px 24px;text-align:center;'>" &
			        "<div style='font-size:40px;'>" & IF(_FA = "Desempeno", "&#128200;", "&#127774;") & "</div>" &
			        "<div style='font-size:17px;font-weight:800;color:#1A3059;margin-top:12px;'>" & IF(_FA = "Desempeno", "En preparacion", "Entrevista de Retiro activa") & "</div>" &
			        "<div style='font-size:12px;color:#53657D;margin-top:9px;line-height:17px;'>" & IF(_FA = "Desempeno", "Este frente forma parte del roadmap corporativo 2026 y estara disponible en la siguiente fase de implementacion.", "Incluye Entrevista de Retiro, Planes de trabajo de Clima Laboral, eNPS de actividades de Bienestar y Cumplimiento del Plan de Bienestar.") & "</div>" &
			        "<div style='margin-top:18px;display:inline-block;border:1.5px solid #1B487F;border-radius:20px;padding:7px 20px;font-size:11px;color:#1B487F;font-weight:700;'>" & IF(_FA = "Desempeno", "Roadmap 2026", "Bienestar en construccion") & "</div></div>" &
			        "<div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>"
			    ))
			VAR _LeftBg = IF(_FA = "Aprendizaje" || _FA = "Desarrollo" || _FA = "Bienestar y Clima", "#ffffff", "#F9FAFC")
			VAR _LeftBorder = IF(_FA = "Aprendizaje" || _FA = "Desarrollo" || _FA = "Bienestar y Clima", "#F7931E", "#DCE5F2")
			VAR _Left = "<div style='position:absolute;left:34px;top:190px;width:592px;height:494px;background:" & _LeftBg & ";border:2px solid " & _LeftBorder & ";border-radius:10px;box-shadow:0 10px 28px rgba(11,28,53,.08);padding:22px;box-sizing:border-box;'>" & _LeftContent & "</div>"
			VAR _CApz = IF(_FA = "Aprendizaje", "<div style='background:#0B1C35;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(11,28,53,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _CDes = IF(_FA = "Desarrollo", "<div style='background:#1B487F;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(27,72,127,.18);'>", "<div style='background:#fff;border:1px solid #E8C99A;border-radius:10px;padding:20px;'>")
			VAR _CDep = IF(_FA = "Desempeno", "<div style='background:#1A3059;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(26,48,89,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _CByC = IF(_FA = "Bienestar y Clima", "<div style='background:#1A3059;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(26,48,89,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _Right =
			    "<div style='position:absolute;left:650px;top:190px;width:598px;height:494px;display:grid;grid-template-columns:1fr 1fr;gap:16px;'>" &
			    _CApz & "<div style='font-size:11px;color:#F7931E;font-weight:800;'>01</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Aprendizaje","color:#fff;","color:#1A3059;") & "'>Aprendizaje</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Aprendizaje","color:#cbd8e8;","color:#53657D;") & "'>MVP operativo con indicadores activos y lectura ejecutiva.</div><div style='margin-top:13px;height:4px;background:" & IF(_FA="Aprendizaje","#F7931E","#DCE5F2") & ";border-radius:4px;'></div><div style='margin-top:9px;display:grid;grid-template-columns:1fr 1fr;gap:6px;'><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Plan</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Cobertura</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Satisfacci&oacute;n</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Inducci&oacute;n</div><div style='grid-column:1 / span 2;background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Focos</div></div></div>" &
			    _CDep & "<div style='font-size:11px;color:" & IF(_FA="Desempeno","#F7931E","#1B487F") & ";font-weight:800;'>02</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Desempeno","color:#fff;","color:#1A3059;") & "'>Desempe&ntilde;o</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Desempeno","color:#d9e4f2;","color:#53657D;") & "'>Medicion y seguimiento gerencial de resultados.</div><div style='margin-top:16px;display:inline-block;border:1px solid " & IF(_FA="Desempeno","#d9e4f2","#DCE5F2") & ";border-radius:12px;padding:3px 9px;font-size:10px;color:" & IF(_FA="Desempeno","#d9e4f2","#1A3059") & ";'>Roadmap</div></div>" &
			    _CDes & "<div style='font-size:11px;color:#F7931E;font-weight:800;'>03</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Desarrollo","color:#fff;","color:#1A3059;") & "'>Desarrollo</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Desarrollo","color:#d9e4f2;","color:#53657D;") & "'>PDI activos. Avance: " & _PDIAvz & ".</div><div style='margin-top:16px;display:inline-block;background:#FFF2E5;color:#9D5600;border-radius:12px;padding:3px 9px;font-size:10px;font-weight:700;'>En construccion</div></div>" &
			    _CByC & "<div style='font-size:11px;color:" & IF(_FA="Bienestar y Clima","#F7931E","#1B487F") & ";font-weight:800;'>04</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Bienestar y Clima","color:#fff;","color:#1A3059;") & "'>Bienestar y Clima</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Bienestar y Clima","color:#d9e4f2;","color:#53657D;") & "'>Entrevista de Retiro, Clima Laboral, eNPS y Plan de Bienestar.</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:12px;'><div style='border-left:3px solid #F7931E;background:" & IF(_FA="Bienestar y Clima","rgba(255,255,255,.10)","#F7F9FC") & ";border-radius:7px;padding:6px 7px;font-size:9px;'>Entrevista de Retiro</div><div style='background:" & IF(_FA="Bienestar y Clima","rgba(255,255,255,.10)","#F7F9FC") & ";border-radius:7px;padding:6px 7px;font-size:9px;'>Planes Clima Laboral</div><div style='background:" & IF(_FA="Bienestar y Clima","rgba(255,255,255,.10)","#F7F9FC") & ";border-radius:7px;padding:6px 7px;font-size:9px;'>eNPS Bienestar</div><div style='background:" & IF(_FA="Bienestar y Clima","rgba(255,255,255,.10)","#F7F9FC") & ";border-radius:7px;padding:6px 7px;font-size:9px;'>Plan Bienestar</div></div></div>" &
			    "</div>"
			RETURN
			"<div style='width:1280px;height:720px;box-sizing:border-box;position:relative;background:#ffffff;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='height:88px;background:#0B1C35;color:#fff;padding:20px 34px;box-sizing:border-box;display:flex;justify-content:space-between;align-items:center;'>" &
			"<div><div style='font-size:11px;letter-spacing:1.8px;text-transform:uppercase;color:#F7931E;font-weight:700;'>Dashboard Corporativo &middot; Grupo LEMCO</div><div style='font-size:25px;line-height:29px;font-weight:800;margin-top:5px;'>Inicio Corporativo</div></div>" &
			"<div style='font-size:10px;color:#7A9EC2;'>Selecciona un frente &rarr;</div></div>" &
			"<div style='position:absolute;left:34px;top:104px;width:1214px;height:82px;background:#ffffff;border:1px solid #DCE5F2;border-radius:14px;box-sizing:border-box;box-shadow:0 10px 28px rgba(11,28,53,.07);overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:7px;height:82px;background:#F7931E;'></div>" &
			"<div style='position:absolute;left:22px;top:17px;width:178px;'><div style='font-size:10px;font-weight:900;color:#0B1C35;text-transform:uppercase;letter-spacing:1px;'>Contexto de an&aacute;lisis</div><div style='font-size:9px;color:#6B7D93;line-height:13px;margin-top:5px;'>Filtros activos para la lectura ejecutiva del home.</div></div>" &
			"<div style='position:absolute;left:214px;top:12px;width:96px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>A&ntilde;o</div></div>" &
			"<div style='position:absolute;left:322px;top:12px;width:110px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Mes</div></div>" &
			"<div style='position:absolute;left:444px;top:12px;width:136px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Empresa</div></div>" &
			"<div style='position:absolute;left:592px;top:12px;width:136px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Area</div></div>" &
			"<div style='position:absolute;left:740px;top:12px;width:144px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Tipo formaci&oacute;n</div></div>" &
			"<div style='position:absolute;left:896px;top:12px;width:144px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Modalidad</div></div>" &
			"<div style='position:absolute;left:1052px;top:12px;width:186px;height:58px;background:#F7F9FC;border:1px solid #E6EEF5;border-radius:8px;box-sizing:border-box;padding:7px 9px;'><div style='font-size:9px;color:#1A3059;font-weight:800;'>Segmento UC</div></div>" &
			"</div>" &
			_Left &
			_Right &
			"</div>"
		displayFolder: 11 HTML Propuestas
		lineageTag: 1cb83d75-76db-4da5-b3ad-558aa192e4d5

	measure 'HTML Inicio Corporativo Propuesta 2' =
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cobertura = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Satisfaccion = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Entrenamiento = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _IndiceAprendizaje = IF(ISBLANK([KPI Indice Aprendizaje]), "-", FORMAT([KPI Indice Aprendizaje], "0.0%"))
			VAR _IndiceDesarrollo = IF(ISBLANK([KPI Indice Desarrollo]), "-", FORMAT([KPI Indice Desarrollo], "0.0%"))
			RETURN
			"<div style='width:1280px;height:720px;box-sizing:border-box;position:relative;background:#F4F7FB;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:1280px;height:220px;background:linear-gradient(135deg,#000032 0%,#1A3059 54%,#1B487F 100%);color:#ffffff;'>" &
			"<div style='position:absolute;left:42px;top:26px;width:600px;'><div style='font-size:12px;color:#F7931E;letter-spacing:2px;text-transform:uppercase;font-weight:800;'>Grupo LEMCO | People Analytics</div><div style='font-size:35px;line-height:41px;font-weight:850;margin-top:8px;'>Dashboard Corporativo de Desarrollo Organizacional</div><div style='font-size:14px;line-height:20px;color:#dbe6f5;margin-top:12px;width:86%;'>Portada ejecutiva para monitorear frentes de gesti&oacute;n humana con lectura r&aacute;pida, comparaci&oacute;n y priorizaci&oacute;n.</div></div>" &
			"<div style='position:absolute;right:42px;top:34px;width:320px;height:138px;background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.25);border-radius:14px;padding:18px;box-sizing:border-box;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>Frente activo</div><div style='font-size:28px;font-weight:850;margin-top:4px;'>Aprendizaje</div><div style='display:flex;gap:10px;margin-top:18px;'><div style='flex:1;'><div style='font-size:10px;color:#bfd0e4;'>Indice</div><div style='font-size:22px;font-weight:800;'>" & _IndiceAprendizaje & "</div></div><div style='flex:1;'><div style='font-size:10px;color:#bfd0e4;'>Desarrollo</div><div style='font-size:22px;font-weight:800;'>" & _IndiceDesarrollo & "</div></div></div></div></div>" &
			"<div style='position:absolute;left:36px;top:136px;width:1212px;height:92px;background:#ffffff;border-radius:14px;box-shadow:0 14px 38px rgba(11,28,53,.16);border:1px solid #DCE5F2;'><div style='position:absolute;left:18px;top:12px;font-size:12px;font-weight:800;color:#1A3059;text-transform:uppercase;letter-spacing:.8px;'>Explorar por</div></div>" &
			"<div style='position:absolute;left:42px;top:256px;width:1210px;height:164px;display:grid;grid-template-columns:1.2fr .8fr .8fr .8fr;gap:16px;'>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:22px;box-shadow:0 8px 24px rgba(11,28,53,.07);'><div style='font-size:13px;color:#F7931E;font-weight:800;'>Aprendizaje</div><div style='font-size:25px;font-weight:850;margin-top:4px;'>Gestion activa del MVP</div><div style='font-size:13px;color:#53657D;line-height:18px;margin-top:8px;'>Indicadores de formaci&oacute;n, cobertura, satisfacci&oacute;n y entrenamiento.</div><div style='height:7px;background:#E8EEF6;border-radius:8px;margin-top:22px;'><div style='width:78%;height:7px;background:#F7931E;border-radius:8px;'></div></div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Horas</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Horas & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Formaci&oacute;n planificada y ejecutada.</div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Cobertura</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Cobertura & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Asistencia frente al p&uacute;blico objetivo.</div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Satisfacci&oacute;n</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Satisfaccion & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Favorabilidad de las respuestas.</div></div></div>" &
			"<div style='position:absolute;left:42px;top:448px;width:1210px;height:164px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;'>" &
			"<div style='background:#0B1C35;color:#ffffff;border-radius:16px;padding:20px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>Activo</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Aprendizaje</div><div style='font-size:12px;color:#cbd8e8;line-height:17px;margin-top:8px;'>Entrenamiento neto: " & _Entrenamiento & ".</div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:16px;padding:20px;'><div style='font-size:12px;color:#1B487F;font-weight:800;'>Pr&oacute;xima fase</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Desempe&ntilde;o</div><div style='font-size:12px;color:#53657D;line-height:17px;margin-top:8px;'>Espacio reservado para evaluaci&oacute;n y seguimiento.</div></div>" &
			"<div style='background:#ffffff;border:1px solid #F7931E;border-radius:16px;padding:20px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>En construcci&oacute;n</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Desarrollo</div><div style='font-size:12px;color:#53657D;line-height:17px;margin-top:8px;'>PDI y acompa&ntilde;amientos en seguimiento.</div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:16px;padding:18px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>Frente iniciado</div><div style='font-size:23px;font-weight:850;margin-top:7px;'>Bienestar y Clima</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:12px;font-size:10px;color:#1A3059;'><div style='border-left:3px solid #F7931E;background:#F7F9FC;border-radius:7px;padding:7px;'>Entrevista de Retiro</div><div style='background:#F7F9FC;border-radius:7px;padding:7px;'>Planes Clima Laboral</div><div style='background:#F7F9FC;border-radius:7px;padding:7px;'>eNPS Bienestar</div><div style='background:#F7F9FC;border-radius:7px;padding:7px;'>Plan Bienestar</div></div></div></div>" &
			"<div style='position:absolute;left:42px;bottom:26px;width:1210px;height:42px;background:#ffffff;border:1px solid #E1E8F2;border-radius:12px;display:flex;align-items:center;padding:0 18px;box-sizing:border-box;color:#53657D;font-size:12px;'><span style='display:inline-block;width:8px;height:8px;background:#F7931E;border-radius:50%;margin-right:10px;'></span>Lectura sugerida: validar cobertura y satisfacci&oacute;n del frente activo antes de avanzar a focos de gesti&oacute;n.</div></div>"
		displayFolder: 11 HTML Propuestas
		lineageTag: b0132c21-8cd4-4669-8432-92927a52be84

	measure 'HTML Inicio Corporativo Propuesta 3' =
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cobertura = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Satisfaccion = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Onboarding = IF(ISBLANK([Induccion Porcentaje Cumplimiento]), "-", FORMAT([Induccion Porcentaje Cumplimiento], "0.0%"))
			VAR _Entrenamiento = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _PDI = IF(ISBLANK([PDI Total]), "-", FORMAT([PDI Total], "#,0"))
			VAR _AlertasPDI = IF(ISBLANK([PDI Alertas Criticas]), "-", FORMAT([PDI Alertas Criticas], "#,0"))
			RETURN
			"<div style='width:1280px;height:720px;box-sizing:border-box;position:relative;background:#ffffff;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:250px;height:720px;background:#0B1C35;color:#ffffff;padding:32px 24px;box-sizing:border-box;'><div style='font-size:11px;color:#F7931E;letter-spacing:1.7px;text-transform:uppercase;font-weight:800;'>Home estrategico</div><div style='font-size:28px;line-height:32px;font-weight:850;margin-top:12px;'>Mapa de frentes</div><div style='font-size:13px;color:#c8d6e8;line-height:19px;margin-top:16px;'>Una vista madre para navegar la evoluci&oacute;n del Dashboard Corporativo.</div><div style='position:absolute;bottom:34px;left:24px;right:24px;border-top:1px solid rgba(255,255,255,.18);padding-top:18px;font-size:12px;color:#c8d6e8;'>Estado actual<br><span style='color:#F7931E;font-size:20px;font-weight:850;'>Aprendizaje MVP</span></div></div>" &
			"<div style='position:absolute;left:276px;top:26px;width:956px;height:76px;background:#F7F9FC;border:1px solid #DCE5F2;border-radius:14px;box-sizing:border-box;'><div style='position:absolute;left:20px;top:10px;font-size:12px;font-weight:800;color:#1A3059;text-transform:uppercase;letter-spacing:.8px;'>Filtros para lectura corporativa</div></div>" &
			"<div style='position:absolute;left:276px;top:126px;width:956px;height:168px;display:grid;grid-template-columns:1.15fr 1fr 1fr;gap:16px;'>" &
			"<div style='background:#1A3059;color:#ffffff;border-radius:14px;padding:22px;box-shadow:0 12px 30px rgba(11,28,53,.14);'><div style='font-size:12px;color:#F7931E;font-weight:800;'>Frente activo</div><div style='font-size:30px;font-weight:850;margin-top:6px;'>Aprendizaje</div><div style='font-size:12px;color:#d9e4f2;line-height:18px;margin-top:8px;'>Lectura integrada de formaci&oacute;n, cobertura, satisfacci&oacute;n, onboarding y entrenamiento.</div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:14px;padding:20px;'><div style='font-size:12px;color:#53657D;'>Horas de formaci&oacute;n</div><div style='font-size:34px;font-weight:850;color:#1B487F;margin-top:8px;'>" & _Horas & "</div><div style='height:5px;background:#F7931E;border-radius:8px;margin-top:18px;width:72%;'></div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:14px;padding:20px;'><div style='font-size:12px;color:#53657D;'>Cobertura / satisfacci&oacute;n</div><div style='display:flex;gap:20px;margin-top:14px;'><div><div style='font-size:27px;font-weight:850;color:#1B487F;'>" & _Cobertura & "</div><div style='font-size:11px;color:#53657D;'>Cobertura</div></div><div><div style='font-size:27px;font-weight:850;color:#1B487F;'>" & _Satisfaccion & "</div><div style='font-size:11px;color:#53657D;'>Satisfacci&oacute;n</div></div></div></div></div>" &
			"<div style='position:absolute;left:276px;top:320px;width:956px;height:268px;display:grid;grid-template-columns:1.05fr 1fr;gap:18px;'>" &
			"<div style='background:#ffffff;border:1px solid #E1E8F2;border-radius:14px;padding:24px;box-shadow:0 10px 28px rgba(11,28,53,.06);'><div style='font-size:12px;color:#F7931E;text-transform:uppercase;font-weight:800;letter-spacing:1px;'>Ruta corporativa</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px;'>" &
			"<div style='background:#0B1C35;color:#ffffff;border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;'>Aprendizaje</div><div style='font-size:11px;color:#cbd8e8;margin-top:7px;'>Activo | " & _Onboarding & " onboarding</div></div>" &
			"<div style='background:#F7F9FC;border:1px solid #DCE5F2;border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;color:#1A3059;'>Desempe&ntilde;o</div><div style='font-size:11px;color:#53657D;margin-top:7px;'>Pr&oacute;xima fase</div></div>" &
			"<div style='background:#FFF7EE;border:1px solid #F7931E;border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;color:#1A3059;'>Desarrollo</div><div style='font-size:11px;color:#9D5600;margin-top:7px;'>" & _PDI & " PDI | " & _AlertasPDI & " alertas</div></div>" &
			"<div style='background:#F7F9FC;border:1px solid #DCE5F2;border-radius:12px;padding:16px;'><div style='font-size:20px;font-weight:850;color:#1A3059;'>Bienestar y Clima</div><div style='font-size:11px;color:#F7931E;font-weight:800;margin-top:7px;'>Entrevista de Retiro activa</div><div style='font-size:10px;color:#53657D;line-height:14px;margin-top:8px;'>Planes Clima Laboral &bull; eNPS Bienestar &bull; Plan Bienestar</div></div></div></div>" &
			"<div style='background:#0B1C35;color:#ffffff;border-radius:14px;padding:24px;'><div style='font-size:12px;color:#F7931E;text-transform:uppercase;font-weight:800;letter-spacing:1px;'>Foco ejecutivo</div><div style='font-size:25px;line-height:30px;font-weight:850;margin-top:12px;'>Priorizar brechas del frente activo</div><div style='font-size:13px;line-height:19px;color:#d9e4f2;margin-top:12px;'>Entrenamiento neto " & _Entrenamiento & ", cobertura " & _Cobertura & " y satisfacci&oacute;n " & _Satisfaccion & " deben orientar la conversaci&oacute;n gerencial.</div><div style='margin-top:24px;background:#F7931E;color:#0B1C35;border-radius:22px;padding:9px 14px;display:inline-block;font-size:12px;font-weight:850;'>Ir a decisiones del bloque</div></div></div>" &
			"<div style='position:absolute;left:276px;top:616px;width:956px;height:58px;background:#F7F9FC;border:1px solid #DCE5F2;border-radius:14px;display:flex;align-items:center;gap:18px;padding:0 22px;box-sizing:border-box;'><div style='font-size:12px;color:#53657D;'>Escalabilidad futura</div><div style='height:26px;width:1px;background:#DCE5F2;'></div><div style='font-size:12px;color:#1A3059;font-weight:750;'>Los frentes pendientes se mantienen visibles como roadmap para evitar una portada aislada del programa corporativo.</div></div></div>"
		displayFolder: 11 HTML Propuestas
		lineageTag: c9f46c0b-dd6c-4f12-bfec-4558f16abf2f

	measure 'EntrevistaRetiro Total' = COUNTROWS('Fct_EntrevistaRetiro_Unificada')
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: f807b926-f383-42b3-938f-8342e825ccef

	measure 'EntrevistaRetiro Total Validas' = CALCULATE([EntrevistaRetiro Total], 'Fct_EntrevistaRetiro_Unificada'[RegistroValido_Flag] = 1)
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8a939516-4eec-4449-9e88-47861c581f2e

	measure 'EntrevistaRetiro Total No Validas' = CALCULATE([EntrevistaRetiro Total], 'Fct_EntrevistaRetiro_Unificada'[RegistroValido_Flag] = 0)
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 4b22d283-ed26-42b7-87fe-a0dc6dd3b7bd

	measure 'EntrevistaRetiro Porcentaje Validas' = DIVIDE([EntrevistaRetiro Total Validas], [EntrevistaRetiro Total], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 0bbfbc38-cfaa-47ba-8032-b1b0451c79e4

	measure 'EntrevistaRetiro Total Voluntarios' = CALCULATE([EntrevistaRetiro Total Validas], 'Dim_TipoRetiro'[TipoRetiro_Key] = "VOLUNTARIO")
