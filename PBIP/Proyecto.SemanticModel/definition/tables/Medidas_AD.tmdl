		displayFolder: 12 HTML Bienestar
		lineageTag: bc001234-5678-90ab-cdef-bc0012345678

	measure 'Home Pagina Resumen Frente' =
			VAR _Frente = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			RETURN
			    SWITCH(
			        _Frente,
			        "Aprendizaje", "A01 Resumen Ejecutivo Aprendizaje",
			        "Desarrollo", "D01 Resumen Ejecutivo Desarrollo",
			        "Bienestar y Clima", "BC00 Resumen Ejecutivo Bienestar y Clima",
			        "Desempeno", "E01 Desempeno - Proxima Fase",
			        "A01 Resumen Ejecutivo Aprendizaje"
			    )
		displayFolder: 00 Home Corporativo
		lineageTag: 1c4f494b-a83d-4be8-a952-9f52118d950e

	measure 'Home Tooltip Resumen Frente' =
			VAR _Frente = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			RETURN
			    "Ir a " & [Home Pagina Resumen Frente]
		displayFolder: 00 Home Corporativo
		lineageTag: 2771f7ad-7ef2-45bd-9881-9ef6aaf7f9e1

