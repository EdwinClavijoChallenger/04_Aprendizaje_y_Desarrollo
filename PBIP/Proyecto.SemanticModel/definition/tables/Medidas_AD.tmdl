			"<div style='display:flex; align-items:center; margin-bottom:10px;'><span style='background:#F59E0B; color:#fff; font-size:10px; font-weight:700; padding:3px 10px; border-radius:20px; letter-spacing:1px; margin-right:10px;'>EN CONSTRUCCION</span><span style='color:#94A3B8; font-size:10px;'>Modulo 04</span></div>" &
