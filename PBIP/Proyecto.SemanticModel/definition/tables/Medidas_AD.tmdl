		displayFolder: 13 Entrevista Retiro
		lineageTag: ce3fc002-75f7-4c88-9fa7-95a9bd46436f

	measure 'EntrevistaRetiro Total Involuntarios' = CALCULATE([EntrevistaRetiro Total Validas], 'Dim_TipoRetiro'[TipoRetiro_Key] = "INVOLUNTARIO")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 46e0a13f-bc98-4df9-a82c-96381f2b72bc

	measure 'EntrevistaRetiro Porcentaje Voluntarios' = DIVIDE([EntrevistaRetiro Total Voluntarios], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 4b8a6985-b643-4ecd-a112-33f8cf286f2a

	measure 'EntrevistaRetiro Porcentaje Involuntarios' = DIVIDE([EntrevistaRetiro Total Involuntarios], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 084eb376-0877-4fda-998a-b71a897fddda

	measure 'EntrevistaRetiro Total Fuentes' = DISTINCTCOUNT('Dim_FuenteEntrevistaRetiro'[FuenteEntrevista_Key])
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 23a34a57-4d5d-4154-bff4-be8b372bf40f

	measure 'EntrevistaRetiro Motivo Principal' =
			VAR _Tabla =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            ALLSELECTED('Dim_MotivoRetiro'[Motivo_Retiro]),
			            "_Total", [EntrevistaRetiro Total Validas]
			        ),
			        [_Total], DESC,
			        'Dim_MotivoRetiro'[Motivo_Retiro], ASC
			    )
			RETURN
			    COALESCE(CONCATENATEX(_Tabla, 'Dim_MotivoRetiro'[Motivo_Retiro], ", "), "Sin datos")
		displayFolder: 13 Entrevista Retiro
		lineageTag: b053a6f4-7ac9-4eb4-a1b8-c6ae55aceb5f

	measure 'EntrevistaRetiro Total Motivos Distintos' = DISTINCTCOUNT('Dim_MotivoRetiro'[MotivoRetiro_Key])
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 2dcd81c3-e651-4b14-9713-3bd0643b5604

	measure 'EntrevistaRetiro Participacion Motivo' = DIVIDE([EntrevistaRetiro Total Validas], CALCULATE([EntrevistaRetiro Total Validas], ALLSELECTED('Dim_MotivoRetiro'[Motivo_Retiro])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 0773a6dd-436f-4de5-9e6a-cc057fb0e1bf

	measure 'EntrevistaRetiro Participacion UnidadNegocio' = DIVIDE([EntrevistaRetiro Total Validas], CALCULATE([EntrevistaRetiro Total Validas], ALLSELECTED('Dim_UnidadNegocioRetiro'[Unidad_Negocio])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: a8690235-fd4a-4e27-9321-7b0fff4175ea

	measure 'EntrevistaRetiro UnidadNegocio Top' =
			VAR _Tabla =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            ALLSELECTED('Dim_UnidadNegocioRetiro'[Unidad_Negocio]),
			            "_Total", [EntrevistaRetiro Total Validas]
			        ),
			        [_Total], DESC,
			        'Dim_UnidadNegocioRetiro'[Unidad_Negocio], ASC
			    )
			RETURN
			    COALESCE(CONCATENATEX(_Tabla, 'Dim_UnidadNegocioRetiro'[Unidad_Negocio], ", "), "Sin datos")
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8fe1e468-8ed6-4add-9607-40b353ed2d01

	measure 'EntrevistaRetiro Causas Prevenibles' = CALCULATE([EntrevistaRetiro Total Validas], 'Fct_EntrevistaRetiro_Unificada'[CausaPrevenible_Key] = "SI")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 9ce75590-6ec4-420f-880c-ed7f6f627042

	measure 'EntrevistaRetiro Porcentaje Causas Prevenibles' = DIVIDE([EntrevistaRetiro Causas Prevenibles], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 340abcd8-a6e6-4b5d-9996-b6b70dedbf99

	measure 'EntrevistaRetiro Variacion Mensual' = [EntrevistaRetiro Total Validas] - CALCULATE([EntrevistaRetiro Total Validas], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8e8763df-25ca-424c-96c2-a4052a408be1

	measure 'EntrevistaRetiro Variacion Mensual Porcentaje' = DIVIDE([EntrevistaRetiro Variacion Mensual], CALCULATE([EntrevistaRetiro Total Validas], DATEADD('Dim_Calendario'[Date], -1, MONTH)), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 6ecb0227-0552-4d0c-85aa-f4e63bb78d9d

	measure 'EntrevistaRetiro Registros Requieren Plan' = CALCULATE([EntrevistaRetiro Total Validas], 'Fct_EntrevistaRetiro_Unificada'[RequierePlanAccion] = "Si")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 2252ede9-0a9f-4428-ba44-f1e21971f379

