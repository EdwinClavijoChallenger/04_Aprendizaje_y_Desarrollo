table Medidas_AD
	isHidden
	lineageTag: c7badb4a-3661-4961-a120-1576c2314372

	measure 'Plan Actividades Planificadas' = COUNTROWS('Fct_PlanFormacion')
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 13bf49f0-4051-4e59-bc23-7d071075004c

	measure 'Plan Actividades Ejecutadas' = CALCULATE(COUNTROWS('Fct_PlanFormacion'), 'Fct_PlanFormacion'[EstadoFormacion_Key] = "EJECUTADA")
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 9616bacc-cfe9-46d8-a9c4-6718f28557b6

	measure 'Plan Actividades Canceladas' = CALCULATE(COUNTROWS('Fct_PlanFormacion'), 'Fct_PlanFormacion'[EstadoFormacion_Key] = "CANCELADA")
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: e4a58cca-fb3d-46cb-aebe-80b96f1119e2

	measure 'Plan Actividades Reprogramadas' = CALCULATE(COUNTROWS('Fct_PlanFormacion'), 'Fct_PlanFormacion'[EstadoFormacion_Key] = "REPROGRAMADA")
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: da21c0c0-be26-42e8-8110-a1f302dc16fb

	measure 'Plan Actividades Vigentes' = [Plan Actividades Planificadas] - [Plan Actividades Canceladas]
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: ed3fc386-63b2-445b-95f7-451a885e0a14

	measure 'Plan Porcentaje Ejecucion' = DIVIDE([Plan Actividades Ejecutadas], [Plan Actividades Vigentes])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Plan Formacion
		lineageTag: 737a2c66-b4af-454f-bafc-75392baf797f

	measure 'Plan Brecha Actividades' = [Plan Actividades Ejecutadas] - [Plan Actividades Vigentes]
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 750b8677-4138-4a17-b1f5-e376f47c957c

	measure 'Plan Publico Objetivo' = SUM('Fct_PlanFormacion'[PUBLICO OBJETIVO ])
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 54afa7d7-e229-4660-bdae-72111fef494e

	measure 'Plan Asistencia Registrada' = SUM('Fct_PlanFormacion'[ASISTENCIA])
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: cff3cfec-31b2-4cfa-ab36-a18517303712

	measure '% Cobertura' = DIVIDE(SUM('Fct_PlanFormacion'[ASISTENCIA]), SUM('Fct_PlanFormacion'[PUBLICO OBJETIVO ]), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Plan Formacion
		lineageTag: ee9905d4-fe15-4bcd-9d9c-4422c880a6e7

	measure '% Brecha Cobertura' = VAR _p = [% Cobertura] RETURN IF(ISBLANK(_p), BLANK(), MAX(0, 1 - _p))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Plan Formacion
		lineageTag: 298b0543-503c-4670-aca5-40aa2ff218b0

	measure 'Plan Cobertura Asistencia' = [% Cobertura]
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Plan Formacion
		lineageTag: 2f3af5ac-9620-4a61-a5d4-3fbc94b2db22

	measure 'Plan Horas Formacion' = SUM('Fct_PlanFormacion'[TOTAL DE HORAS DE FORMACIÓN ])
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: e053ccaa-25eb-4072-9620-4571a48635ee

	measure 'Plan Total Horas Formacion' = SUM('Fct_PlanFormacion'[TOTAL DE HORAS DE FORMACIÓN ])
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: cf9e0ed7-bde3-405d-907d-af0daa4372e8

	measure 'Plan Costo' = SUM('Fct_PlanFormacion'[COSTO])
		formatString: $ #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 49cbeab6-ceb6-4613-987c-a8c3f50ecff5

	measure 'Asistencia Total Registros' = COUNTROWS('Fct_AsistenciaFormacion')
		formatString: #,0
		displayFolder: 02 Asistencia
		lineageTag: 3d393594-40cc-41a2-8cd3-a8f9c1e0bb12

	measure 'Asistencia Total Asistentes' = [Asistencia Total Registros]
		formatString: #,0
		displayFolder: 02 Asistencia
		lineageTag: 1872009d-5975-4079-a676-f9c0916a9862

	measure 'Asistencia Participantes Unicos' = DISTINCTCOUNT('Fct_AsistenciaFormacion'[Número de documento del participante])
		formatString: #,0
		displayFolder: 02 Asistencia
		lineageTag: 2c935cb8-e80e-4265-8a82-945c88b62868

	measure 'Asistencia Formaciones' = DISTINCTCOUNT('Fct_AsistenciaFormacion'[TemaFormacion_Key])
		formatString: #,0
		displayFolder: 02 Asistencia
		lineageTag: 2b7fd8ae-1e97-427e-9e8f-338bbcc3a95f

	measure 'Asistencia Total Convocados' = [Plan Publico Objetivo]
		formatString: #,0
		displayFolder: 02 Asistencia
		lineageTag: 1d864477-151b-4977-b05a-c828a4d16009

	measure 'Asistencia Porcentaje Asistencia' = DIVIDE([Asistencia Total Asistentes], [Asistencia Total Convocados])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 02 Asistencia
		lineageTag: d8f8cff2-0bc9-4438-8a9a-43b36d82ef04

	measure 'Asistencia Porcentaje Ausentismo' = VAR _p = [Asistencia Porcentaje Asistencia] RETURN IF(ISBLANK(_p), BLANK(), MAX(0, 1 - _p))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 02 Asistencia
		lineageTag: 7e98b418-ad44-44df-953f-833d88f95c91

	measure 'Asistencia Promedio Por Formacion' = DIVIDE([Asistencia Total Asistentes], [Asistencia Formaciones])
		formatString: #,0.0
		displayFolder: 02 Asistencia
		lineageTag: 2b93e2e1-8605-4a8f-badb-120a66ee5f51

	measure 'Encuesta Total Respuestas' = COUNTROWS('Fct_EncuestaFormacion')
		formatString: #,0
		displayFolder: 03 Encuesta Formacion
		lineageTag: 8f3cef95-8fb8-44b3-8e1b-657872806636

	measure 'Encuesta Participantes Estimados' = [Encuesta Total Respuestas]
		formatString: #,0
		displayFolder: 03 Encuesta Formacion
		lineageTag: 8dce703a-0eee-483d-8bf2-2bf8feb77912

	measure 'Encuesta Tasa Respuesta' = DIVIDE([Encuesta Total Respuestas], [Asistencia Total Asistentes])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 03 Encuesta Formacion
		lineageTag: 8c5290a2-677e-40b0-8c40-f693077cfdb5

	measure 'Encuesta Calificacion Promedio' =
			VAR _Suma =
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el dominio del tema por parte del facilitador?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la habilidad para comunicarse y transmitir ideas por parte del facilitador?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con las actividades o ejercicios por parte del facilitador?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el uso de ayudas didácticas por parte del facilitador?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la resolución de dudas u observaciones del facilitador?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el cumplimiento del programa propuesto?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el espacio, logística y ambiente de la formación?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan oportuna fue la información respecto a fechas, horarios y lugar?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el logro de los objetivos propuestos?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la contribución del programa para tu desarrollo personal y/o profesional?]) +
			    SUM('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el acompañamiento de la Universidad Challenger en tu desarrollo personal y/o profesional?]) +
			    SUM('Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?])
			VAR _Conteo =
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el dominio del tema por parte del facilitador?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la habilidad para comunicarse y transmitir ideas por parte del facilitador?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con las actividades o ejercicios por parte del facilitador?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el uso de ayudas didácticas por parte del facilitador?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la resolución de dudas u observaciones del facilitador?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el cumplimiento del programa propuesto?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el espacio, logística y ambiente de la formación?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan oportuna fue la información respecto a fechas, horarios y lugar?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el logro de los objetivos propuestos?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con la contribución del programa para tu desarrollo personal y/o profesional?]) +
			    COUNT('Fct_EncuestaFormacion'[¿Qué tan satisfecho te encuentras con el acompañamiento de la Universidad Challenger en tu desarrollo personal y/o profesional?]) +
			    COUNT('Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?])
			RETURN
			    DIVIDE(_Suma, _Conteo)
		formatString: 0.00
		displayFolder: 03 Encuesta Formacion
		lineageTag: 66d4c70a-b055-4891-9abe-6d10eda690dc

	measure 'Encuesta Favorabilidad' = DIVIDE(CALCULATE(COUNTROWS('Fct_EncuestaFormacion'), 'Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?] >= 4), [Encuesta Total Respuestas])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 03 Encuesta Formacion
		lineageTag: 4444042a-1946-4ca9-97e1-6be11e260c0e

	measure 'Encuesta NPS Equivalente' =
			VAR _Total = COUNT('Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?])
			VAR _Promotores = CALCULATE(COUNTROWS('Fct_EncuestaFormacion'), 'Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?] >= 5)
			VAR _Detractores = CALCULATE(COUNTROWS('Fct_EncuestaFormacion'), 'Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?] <= 3)
			RETURN
			    DIVIDE(_Promotores - _Detractores, _Total) * 100
		formatString: 0.0
		displayFolder: 03 Encuesta Formacion
		lineageTag: 3124a3a4-d281-4ef4-86de-717a9d7fd907

	measure 'Induccion Total Colaboradores' = COUNTROWS('Fct_Induccion')
		formatString: #,0
		displayFolder: 04 Induccion UC
		lineageTag: 3b28d7f6-130e-4260-bfe3-d840ffa3bdbb

	measure 'Induccion Colaboradores Unicos' = DISTINCTCOUNT('Fct_Induccion'[Colaborador_Key])
		formatString: #,0
		displayFolder: 04 Induccion UC
		lineageTag: 24f1148a-539f-4465-b843-3ed95f9b4368

	measure 'Induccion Aprobados' = CALCULATE(COUNTROWS('Fct_Induccion'), 'Fct_Induccion'[EstadoInduccion_Key] IN { "APROBO", "APROBADO" })
		formatString: #,0
		displayFolder: 04 Induccion UC
		lineageTag: 0ac88ffa-7bc3-45b7-909d-a74217a123d4

	measure 'Induccion No Aprobados' = CALCULATE(COUNTROWS('Fct_Induccion'), 'Fct_Induccion'[EstadoInduccion_Key] = "NO_APROBO")
		formatString: #,0
		displayFolder: 04 Induccion UC
		lineageTag: ccffef5a-a187-4ddb-bd64-5755dbebdf3e

	measure 'Induccion Retiros' = CALCULATE(COUNTROWS('Fct_Induccion'), 'Fct_Induccion'[EstadoInduccion_Key] IN { "RETIRADO", "RENUNCIA" })
		formatString: #,0
		displayFolder: 04 Induccion UC
		lineageTag: e4a40db9-198d-4158-9ccc-1cb3261f9fd2

	measure 'Induccion Onboarding' = DIVIDE([Induccion Onboarding Realizados], [Induccion Onboarding Participantes], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 04 Induccion UC
		lineageTag: 7afb6905-9eeb-4444-8d1b-1dc1550c66ab

	measure 'Induccion Minutos Entrenamiento' = SUM('Fct_Induccion'[Min_Entrenamiento])
		formatString: #,0
