	measure 'Asistencia Registros HC Match' =
			VAR _KeysHC = VALUES('Dim_ColaboradorHC'[Colaborador_Key])
			RETURN
			    CALCULATE(
			        [Asistencia Total Registros],
			        TREATAS(_KeysHC, 'Fct_AsistenciaFormacion'[Colaborador_Key])
			    )
		formatString: #,0
		displayFolder: 08 Headcount HC
		lineageTag: d21be951-d44a-4d57-a66d-dd46c9b1caa4

	measure 'Asistencia Colaborador Mes HC Match' =
			VAR _KeysHC = VALUES('Dim_ColaboradorHC'[Colaborador_Key])
			RETURN
			    CALCULATE(
			        DISTINCTCOUNT('Fct_AsistenciaFormacion'[Colaborador_Key]),
			        TREATAS(_KeysHC, 'Fct_AsistenciaFormacion'[Colaborador_Key])
			    )
