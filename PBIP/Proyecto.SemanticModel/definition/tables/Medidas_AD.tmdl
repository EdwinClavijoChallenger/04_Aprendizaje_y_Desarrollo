	measure 'PDI Porcentaje Por Estado' = DIVIDE([PDI Total], CALCULATE([PDI Total], ALLSELECTED('Dim_EstadoPDI'[Estado_PDI])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: 707e9860-ed38-4dc1-a671-8117f3762692

	measure 'PDI Porcentaje Por Motivo' = DIVIDE([PDI Total], CALCULATE([PDI Total], ALLSELECTED('Dim_MotivoPDI'[Motivo_PDI])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: ebfc3785-f433-4bea-818b-bb45d4c0cb4b

	measure 'PDI Avance Cero' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        COALESCE('Fct_Seguimiento_PDI'[Avance_PDI], 0) = 0
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 086d71ab-3c67-4838-b895-5970f0cb7e0c

	measure 'PDI Bajo Avance' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        VAR _Avance = IF('Fct_Seguimiento_PDI'[Avance_PDI] > 1, DIVIDE('Fct_Seguimiento_PDI'[Avance_PDI], 100), 'Fct_Seguimiento_PDI'[Avance_PDI])
			        RETURN _Avance > 0 && _Avance < 0.4
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 9e73a3c1-e8bd-42f3-97d3-cd63918c668c

	measure 'PDI Vencidos' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] < TODAY()
			            && NOT (
			                'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			            )
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 310e0db2-f0d1-4d70-a8b7-5b8147cfcc09

	measure 'PDI Proximos A Vencer' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] >= TODAY()
			            && 'Fct_Seguimiento_PDI'[Fecha_Fin] <= TODAY() + 30
			            && NOT (
			                'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			            )
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: e7d2735e-d44e-4d17-8a64-49ad6772b7ab

	measure 'PDI Acompanamientos Programados' =
			CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_1] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_2] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_3] IN { "P", "E", "PROGRAMADO", "EJECUTADO" })
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 2930cd49-066d-46c1-8af5-c7b11eea1c81

	measure 'PDI Acompanamientos Ejecutados' =
			CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_1] IN { "E", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_2] IN { "E", "EJECUTADO" })
			    + CALCULATE([PDI Total], 'Fct_Seguimiento_PDI'[Acompanamiento_3] IN { "E", "EJECUTADO" })
		formatString: #,0
		displayFolder: 09 Desarrollo PDI
		lineageTag: 7b38b540-17ee-4260-8b71-af862d8ebc4f

	measure 'PDI Cumplimiento Acompanamientos' = DIVIDE([PDI Acompanamientos Ejecutados], [PDI Acompanamientos Programados], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 09 Desarrollo PDI
		lineageTag: c052eeff-33ed-4762-b7b8-09026516a598

	measure 'PDI Alertas Criticas' =
			CALCULATE(
			    [PDI Total],
			    FILTER(
			        'Fct_Seguimiento_PDI',
			        VAR _Avance = IF('Fct_Seguimiento_PDI'[Avance_PDI] > 1, DIVIDE('Fct_Seguimiento_PDI'[Avance_PDI], 100), 'Fct_Seguimiento_PDI'[Avance_PDI])
			        VAR _Vencido =
			            NOT ISBLANK('Fct_Seguimiento_PDI'[Fecha_Fin])
			                && 'Fct_Seguimiento_PDI'[Fecha_Fin] < TODAY()
			                && NOT (
			                    'Fct_Seguimiento_PDI'[EstadoPDI_Key] IN { "FINALIZADO", "CERRADO", "COMPLETADO", "CANCELADO" }
			                )
			        RETURN COALESCE(_Avance, 0) = 0 || (_Avance > 0 && _Avance < 0.4) || _Vencido
			    )
			)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 5acc123f-755e-4c25-85f0-8f26d30a6718

	measure 'PDI Ranking Area Total' = RANKX(ALLSELECTED('Dim_Area'[Area]), [PDI Total], , DESC, Dense)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: b35f3a01-d64d-475a-92b0-984816763f7b

	measure 'PDI Ranking Jefe Bajo Avance' = RANKX(ALLSELECTED('Fct_Seguimiento_PDI'[Jefe_Inmediato]), [PDI Bajo Avance], , DESC, Dense)
		formatString: #,0
		displayFolder: 10 Desarrollo Alertas
		lineageTag: 4d23f49d-100d-4fcd-9bc6-af3e454183f7

	measure 'KPI Indice Desarrollo' =
			VAR _SinVencidos = 1 - DIVIDE([PDI Vencidos], [PDI Total], 0)
			VAR _Base =
			    {
			        [PDI Avance Promedio],
			        [PDI Cumplimiento Acompanamientos],
			        _SinVencidos
			    }
			RETURN
			    AVERAGEX(FILTER(_Base, NOT ISBLANK([Value])), [Value])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 00 KPIs Gerenciales
		lineageTag: e1b75bcf-3df0-489e-9ccb-f0d3d97846fb

	measure 'HTML Inicio Corporativo Propuesta 1' =
			VAR _FA = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cob = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Sat = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Onb = IF(ISBLANK([Induccion Porcentaje Cumplimiento]), "-", FORMAT([Induccion Porcentaje Cumplimiento], "0.0%"))
			VAR _Ent = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _IApz = IF(ISBLANK([KPI Indice Aprendizaje]), "-", FORMAT([KPI Indice Aprendizaje], "0.0%"))
			VAR _PDIAct = IF(ISBLANK([PDI Activos]), "-", FORMAT([PDI Activos], "#,0"))
			VAR _PDIAvz = IF(ISBLANK([PDI Avance Promedio]), "-", FORMAT([PDI Avance Promedio], "0.0%"))
			VAR _PDIAvzBar = IF(ISBLANK([PDI Avance Promedio]), "0%", FORMAT(MIN([PDI Avance Promedio], 1), "0.0%"))
			VAR _PDIAlt = IF(ISBLANK([PDI Alertas Criticas]), "-", FORMAT([PDI Alertas Criticas], "#,0"))
			VAR _Acomp = IF(ISBLANK([PDI Cumplimiento Acompanamientos]), "-", FORMAT([PDI Cumplimiento Acompanamientos], "0.0%"))
			VAR _IDes = IF(ISBLANK([KPI Indice Desarrollo]), "-", FORMAT([KPI Indice Desarrollo], "0.0%"))
			VAR _PDIMot = COALESCE([PDI Motivo Principal], "Sin datos")
			VAR _PDIEst = COALESCE([PDI Estado Principal], "Sin datos")
			VAR _ERet = IF(ISBLANK([EntrevistaRetiro Total Validas]), "-", FORMAT([EntrevistaRetiro Total Validas], "#,0"))
			VAR _EPrev = IF(ISBLANK([EntrevistaRetiro Porcentaje Causas Prevenibles]), "-", FORMAT([EntrevistaRetiro Porcentaje Causas Prevenibles], "0.0%"))
			VAR _EVolPct = IF(ISBLANK([EntrevistaRetiro Porcentaje Voluntarios]), "-", FORMAT([EntrevistaRetiro Porcentaje Voluntarios], "0.0%"))
			VAR _BProg = IF(ISBLANK([Bienestar Programaciones Registradas Ejecucion]), "-", FORMAT([Bienestar Programaciones Registradas Ejecucion], "#,0"))
			VAR _BEjec = IF(ISBLANK([Bienestar Ejecutadas]), "-", FORMAT([Bienestar Ejecutadas], "#,0"))
			VAR _BCump = IF(ISBLANK([Bienestar Cumplimiento al Corte %]), "-", FORMAT([Bienestar Cumplimiento al Corte %], "0.0%"))
			VAR _DesCobComp = IF(ISBLANK([Competencias Cobertura %]), "-", FORMAT([Competencias Cobertura %], "0.0%"))
			VAR _DesCobObj = IF(ISBLANK([Desempeno Cobertura Objetivos %]), "-", FORMAT([Desempeno Cobertura Objetivos %], "0.0%"))
			VAR _DesPromComp = IF(ISBLANK([Competencias Promedio]), "-", FORMAT([Competencias Promedio], "0.0"))
			VAR _NivelCritico = CALCULATE([Desempeno % por Nivel], 'Fct_Desempeno_2025'[Interpretacion_Homologada] = "Crítico")
			VAR _NivelBajo = CALCULATE([Desempeno % por Nivel], 'Fct_Desempeno_2025'[Interpretacion_Homologada] = "Bajo")
			VAR _NivelIntermedio = CALCULATE([Desempeno % por Nivel], 'Fct_Desempeno_2025'[Interpretacion_Homologada] = "Intermedio")
			VAR _NivelAlto = CALCULATE([Desempeno % por Nivel], 'Fct_Desempeno_2025'[Interpretacion_Homologada] = "Alto")
			VAR _NivelAvanzado = CALCULATE([Desempeno % por Nivel], 'Fct_Desempeno_2025'[Interpretacion_Homologada] = "Avanzado")
			VAR _NivelCriticoTxt = IF(ISBLANK(_NivelCritico), "-", FORMAT(_NivelCritico, "0%"))
			VAR _NivelBajoTxt = IF(ISBLANK(_NivelBajo), "-", FORMAT(_NivelBajo, "0%"))
			VAR _NivelIntermedioTxt = IF(ISBLANK(_NivelIntermedio), "-", FORMAT(_NivelIntermedio, "0%"))
			VAR _NivelAltoTxt = IF(ISBLANK(_NivelAlto), "-", FORMAT(_NivelAlto, "0%"))
			VAR _NivelAvanzadoTxt = IF(ISBLANK(_NivelAvanzado), "-", FORMAT(_NivelAvanzado, "0%"))
			VAR _NivelCriticoBar = IF(ISBLANK(_NivelCritico), "0%", FORMAT(MIN(_NivelCritico, 1), "0%"))
			VAR _NivelBajoBar = IF(ISBLANK(_NivelBajo), "0%", FORMAT(MIN(_NivelBajo, 1), "0%"))
			VAR _NivelIntermedioBar = IF(ISBLANK(_NivelIntermedio), "0%", FORMAT(MIN(_NivelIntermedio, 1), "0%"))
			VAR _NivelAltoBar = IF(ISBLANK(_NivelAlto), "0%", FORMAT(MIN(_NivelAlto, 1), "0%"))
			VAR _NivelAvanzadoBar = IF(ISBLANK(_NivelAvanzado), "0%", FORMAT(MIN(_NivelAvanzado, 1), "0%"))
			VAR _CtaTexto =
			    SWITCH(
			        _FA,
			        "Aprendizaje", "Ver tablero completo de Aprendizaje",
			        "Desarrollo", "Ver resumen ejecutivo de Desarrollo",
			        "Bienestar y Clima", "Ver tablero completo de Bienestar y Clima",
			        "Desempeño", "Ver frente Desempe&ntilde;o",
			        "Ver tablero completo de Aprendizaje"
			    )
			VAR _LeftContent =
			    IF(_FA = "Aprendizaje",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Aprendizaje</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>Formaci&oacute;n, cobertura, satisfacci&oacute;n, onboarding y entrenamiento inicial.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Horas formaci&oacute;n</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Horas & "</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Cobertura</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Cob & "</div></div>" &
			        "<div style='border-left:4px solid #1A3059;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Satisfacci&oacute;n</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Sat & "</div></div>" &
			        "<div style='border-left:4px solid #0B1C35;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Onboarding</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _Onb & "</div></div>" &
			        "</div><div style='display:flex;gap:10px;margin-top:11px;'>" &
			        "<div style='flex:1;background:#0B1C35;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Entrenamiento neto</div><div style='font-size:21px;font-weight:800;'>" & _Ent & "</div></div>" &
			        "<div style='flex:1;background:#1B487F;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Indice Aprendizaje</div><div style='font-size:21px;font-weight:800;'>" & _IApz & "</div></div>" &
			        "</div><div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>",
			    IF(_FA = "Desarrollo",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Desarrollo</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>PDI, movilidad, sucesi&oacute;n y cargos cr&iacute;ticos.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;overflow:hidden;'><div style='font-size:9px;color:#53657D;text-transform:uppercase;letter-spacing:0.9px;'>Motivo PDI</div><div style='font-size:12px;font-weight:800;color:#1B487F;margin-top:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'>" & _PDIMot & "</div><div style='margin-top:6px;display:inline-block;background:#F7931E;color:#fff;border-radius:10px;padding:2px 8px;font-size:9px;font-weight:700;'>Principal</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;overflow:hidden;'><div style='font-size:9px;color:#53657D;text-transform:uppercase;letter-spacing:0.9px;'>Estado &middot; Avance</div><div style='display:flex;align-items:center;gap:7px;margin-top:5px;'><span style='background:#1B487F;color:#fff;border-radius:10px;padding:2px 8px;font-size:9px;font-weight:700;white-space:nowrap;overflow:hidden;max-width:110px;'>" & _PDIEst & "</span><span style='font-size:17px;font-weight:800;color:#1B487F;'>" & _PDIAvz & "</span></div><div style='margin-top:6px;height:4px;background:#D8E4F0;border-radius:2px;'><div style='width:" & _PDIAvzBar & ";height:4px;background:#1B487F;border-radius:2px;'></div></div></div>" &
			        "</div><div style='display:flex;gap:8px;margin-top:11px;'>" &
			        "<div style='flex:1;background:#F7F9FC;border:1px dashed #B0C4D8;border-radius:8px;padding:9px 11px;'><div style='font-size:10px;color:#53657D;'>Movilidad</div><div style='font-size:12px;color:#53657D;font-style:italic;font-weight:700;margin-top:3px;'>Pendiente</div></div>" &
			        "<div style='flex:1;background:#F7F9FC;border:1px dashed #B0C4D8;border-radius:8px;padding:9px 11px;'><div style='font-size:10px;color:#53657D;'>Sucesi&oacute;n</div><div style='font-size:12px;color:#53657D;font-style:italic;font-weight:700;margin-top:3px;'>Pendiente</div></div>" &
			        "<div style='flex:1;background:#F7F9FC;border:1px dashed #B0C4D8;border-radius:8px;padding:9px 11px;'><div style='font-size:10px;color:#53657D;'>Cargos cr&iacute;ticos</div><div style='font-size:12px;color:#53657D;font-style:italic;font-weight:700;margin-top:3px;'>Pendiente</div></div>" &
			        "</div><div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>",
			    IF(_FA = "Bienestar y Clima",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Bienestar y Clima</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>Entrevista de Retiro y Plan de Bienestar activos. Clima laboral y eNPS en roadmap.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Entrevistas v&aacute;lidas</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _ERet & "</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Causas prevenibles</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _EPrev & "</div></div>" &
			        "<div style='border-left:4px solid #1A3059;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Programaciones vigentes</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _BProg & "</div></div>" &
			        "<div style='border-left:4px solid #0B1C35;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Actividades ejecutadas</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _BEjec & "</div></div>" &
			        "</div><div style='display:flex;gap:10px;margin-top:11px;'>" &
			        "<div style='flex:1;background:#0B1C35;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Retiros voluntarios</div><div style='font-size:21px;font-weight:800;'>" & _EVolPct & "</div></div>" &
			        "<div style='flex:1;background:#1B487F;color:#fff;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#b8c8de;'>Cumplimiento al corte</div><div style='font-size:21px;font-weight:800;'>" & _BCump & "</div></div>" &
			        "</div><div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>",
			        "<div style='font-size:11px;color:#F7931E;font-weight:800;text-transform:uppercase;letter-spacing:1.4px;'>Frente activo</div>" &
			        "<div style='font-size:30px;font-weight:800;margin-top:4px;color:#000032;'>Desempe&ntilde;o</div>" &
			        "<div style='font-size:12px;color:#53657D;line-height:17px;margin-top:7px;'>Medici&oacute;n de objetivos, competencias y evoluci&oacute;n del desempe&ntilde;o organizacional.</div>" &
			        "<div style='display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:15px;'>" &
			        "<div style='border-left:4px solid #F7931E;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Cobertura competencias</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _DesCobComp & "</div></div>" &
			        "<div style='border-left:4px solid #1B487F;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Cobertura objetivos</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _DesCobObj & "</div></div>" &
			        "<div style='border-left:4px solid #1A3059;background:#F7F9FC;border-radius:8px;padding:11px 13px;'><div style='font-size:10px;color:#53657D;'>Promedio competencias</div><div style='font-size:25px;font-weight:800;color:#1B487F;'>" & _DesPromComp & "</div></div>" &
			        "<div style='border-left:4px solid #0B1C35;background:#F7F9FC;border-radius:8px;padding:9px 11px;'><div style='font-size:10px;color:#53657D;'>Curva por niveles</div>" &
			        "<div style='display:grid;gap:3px;margin-top:6px;font-size:8px;color:#53657D;'>" &
			        "<div style='display:grid;grid-template-columns:52px 1fr 26px;align-items:center;gap:5px;'><span>Cr&iacute;tico</span><span style='height:5px;background:#DCE5F2;border-radius:6px;'><span style='display:block;width:" & _NivelCriticoBar & ";height:5px;background:#F7931E;border-radius:6px;'></span></span><b style='color:#1B487F;text-align:right;'>" & _NivelCriticoTxt & "</b></div>" &
			        "<div style='display:grid;grid-template-columns:52px 1fr 26px;align-items:center;gap:5px;'><span>Bajo</span><span style='height:5px;background:#DCE5F2;border-radius:6px;'><span style='display:block;width:" & _NivelBajoBar & ";height:5px;background:#1A3059;border-radius:6px;'></span></span><b style='color:#1B487F;text-align:right;'>" & _NivelBajoTxt & "</b></div>" &
			        "<div style='display:grid;grid-template-columns:52px 1fr 26px;align-items:center;gap:5px;'><span>Intermedio</span><span style='height:5px;background:#DCE5F2;border-radius:6px;'><span style='display:block;width:" & _NivelIntermedioBar & ";height:5px;background:#1B487F;border-radius:6px;'></span></span><b style='color:#1B487F;text-align:right;'>" & _NivelIntermedioTxt & "</b></div>" &
			        "<div style='display:grid;grid-template-columns:52px 1fr 26px;align-items:center;gap:5px;'><span>Alto</span><span style='height:5px;background:#DCE5F2;border-radius:6px;'><span style='display:block;width:" & _NivelAltoBar & ";height:5px;background:#1B487F;border-radius:6px;'></span></span><b style='color:#1B487F;text-align:right;'>" & _NivelAltoTxt & "</b></div>" &
			        "<div style='display:grid;grid-template-columns:52px 1fr 26px;align-items:center;gap:5px;'><span>Avanzado</span><span style='height:5px;background:#DCE5F2;border-radius:6px;'><span style='display:block;width:" & _NivelAvanzadoBar & ";height:5px;background:#0B1C35;border-radius:6px;'></span></span><b style='color:#1B487F;text-align:right;'>" & _NivelAvanzadoTxt & "</b></div>" &
			        "</div></div></div>" &
			        "<div style='position:absolute;left:22px;bottom:26px;width:548px;text-align:center;background:#F7931E;color:#fff;border-radius:8px;padding:9px;font-size:11px;font-weight:800;box-sizing:border-box;'>" & _CtaTexto & "</div>"
			    )))
			VAR _LeftBg = IF(_FA = "Aprendizaje" || _FA = "Desarrollo" || _FA = "Bienestar y Clima" || _FA = "Desempeño", "#ffffff", "#F9FAFC")
			VAR _LeftBorder = IF(_FA = "Aprendizaje" || _FA = "Desarrollo" || _FA = "Bienestar y Clima" || _FA = "Desempeño", "#F7931E", "#DCE5F2")
			VAR _Left = "<div style='position:absolute;left:34px;top:190px;width:592px;height:494px;background:" & _LeftBg & ";border:2px solid " & _LeftBorder & ";border-radius:10px;box-shadow:0 10px 28px rgba(11,28,53,.08);padding:22px;box-sizing:border-box;'>" & _LeftContent & "</div>"
			VAR _CApz = IF(_FA = "Aprendizaje", "<div style='background:#0B1C35;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(11,28,53,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _CDes = IF(_FA = "Desarrollo", "<div style='background:#1B487F;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(27,72,127,.18);'>", "<div style='background:#fff;border:1px solid #E8C99A;border-radius:10px;padding:20px;'>")
			VAR _CDep = IF(_FA = "Desempeño", "<div style='background:#1A3059;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(26,48,89,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _CByC = IF(_FA = "Bienestar y Clima", "<div style='background:#1A3059;color:#fff;border-radius:10px;padding:20px;border:2px solid #F7931E;box-shadow:0 8px 22px rgba(26,48,89,.18);'>", "<div style='background:#fff;border:1px solid #DCE5F2;border-radius:10px;padding:20px;'>")
			VAR _Right =
			    "<div style='position:absolute;left:650px;top:190px;width:598px;height:494px;display:grid;grid-template-columns:1fr 1fr;gap:16px;'>" &
			    _CApz & "<div style='font-size:11px;color:#F7931E;font-weight:800;'>01</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Aprendizaje","color:#fff;","color:#1A3059;") & "'>Aprendizaje</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Aprendizaje","color:#cbd8e8;","color:#53657D;") & "'>MVP operativo con indicadores activos y lectura ejecutiva.</div><div style='margin-top:13px;height:4px;background:" & IF(_FA="Aprendizaje","#F7931E","#DCE5F2") & ";border-radius:4px;'></div><div style='margin-top:9px;display:grid;grid-template-columns:1fr 1fr;gap:6px;'><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Plan</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Cobertura</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Satisfacci&oacute;n</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Inducci&oacute;n</div><div style='grid-column:1 / span 2;background:rgba(255,255,255,.12);color:" & IF(_FA="Aprendizaje","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Aprendizaje","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Focos</div></div></div>" &
			    _CDep & "<div style='font-size:11px;color:" & IF(_FA="Desempeño","#F7931E","#1B487F") & ";font-weight:800;'>02</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Desempeño","color:#fff;","color:#1A3059;") & "'>Desempe&ntilde;o</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Desempeño","color:#d9e4f2;","color:#53657D;") & "'>Medici&oacute;n y seguimiento gerencial de resultados.</div><div style='margin-top:12px;display:grid;grid-template-columns:1fr 1fr;gap:6px;'><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Objetivos</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Desempeño","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Desempeño","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Competencias</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Desempeño","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Desempeño","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Curva niveles</div><div style='background:rgba(255,255,255,.12);color:" & IF(_FA="Desempeño","#fff","#1A3059") & ";border:1px solid " & IF(_FA="Desempeño","rgba(255,255,255,.22)","#DCE5F2") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Detalle</div></div></div>" &
			    _CDes & "<div style='font-size:11px;color:#F7931E;font-weight:800;'>03</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Desarrollo","color:#fff;","color:#1A3059;") & "'>Desarrollo</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Desarrollo","color:#d9e4f2;","color:#53657D;") & "'>PDI activos. Avance: " & _PDIAvz & ".</div><div style='margin-top:12px;display:grid;grid-template-columns:1fr 1fr;gap:6px;'><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>PDI</div><div style='background:rgba(255,255,255,.08);color:" & IF(_FA="Desarrollo","#d9e4f2","#53657D") & ";border:1px dashed " & IF(_FA="Desarrollo","rgba(255,255,255,.28)","#B0C4D8") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Movilidad</div><div style='background:rgba(255,255,255,.08);color:" & IF(_FA="Desarrollo","#d9e4f2","#53657D") & ";border:1px dashed " & IF(_FA="Desarrollo","rgba(255,255,255,.28)","#B0C4D8") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Sucesi&oacute;n</div><div style='background:rgba(255,255,255,.08);color:" & IF(_FA="Desarrollo","#d9e4f2","#53657D") & ";border:1px dashed " & IF(_FA="Desarrollo","rgba(255,255,255,.28)","#B0C4D8") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Cargos cr&iacute;ticos</div></div></div>" &
			    _CByC & "<div style='font-size:11px;color:" & IF(_FA="Bienestar y Clima","#F7931E","#1B487F") & ";font-weight:800;'>04</div><div style='font-size:19px;font-weight:800;margin-top:7px;" & IF(_FA="Bienestar y Clima","color:#fff;","color:#1A3059;") & "'>Bienestar y Clima</div><div style='font-size:10px;line-height:15px;margin-top:8px;" & IF(_FA="Bienestar y Clima","color:#d9e4f2;","color:#53657D;") & "'>Retiro y Plan Bienestar activos. Clima y eNPS en roadmap.</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:12px;'><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Entrevista de Retiro</div><div style='background:#F7931E;color:#fff;border-radius:12px;padding:5px 9px;font-size:9px;font-weight:800;text-align:center;'>Plan Bienestar</div><div style='background:rgba(255,255,255,.06);color:" & IF(_FA="Bienestar y Clima","#b8c8de","#9DB5CC") & ";border:1px dashed " & IF(_FA="Bienestar y Clima","rgba(255,255,255,.22)","#B0C4D8") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:700;text-align:center;'>Planes Clima Laboral</div><div style='background:rgba(255,255,255,.06);color:" & IF(_FA="Bienestar y Clima","#b8c8de","#9DB5CC") & ";border:1px dashed " & IF(_FA="Bienestar y Clima","rgba(255,255,255,.22)","#B0C4D8") & ";border-radius:12px;padding:5px 9px;font-size:9px;font-weight:700;text-align:center;'>eNPS Bienestar</div></div></div>" &
