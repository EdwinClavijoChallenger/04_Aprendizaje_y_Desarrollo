	measure 'Encuesta Calificacion Satisfaccion Formacion' = AVERAGE('Fct_EncuestaFormacion'[En general, ¿Qué tan satisfecho te encuentras con la formación recibida?])
		formatString: 0.00
		displayFolder: 03 Encuesta Formacion
