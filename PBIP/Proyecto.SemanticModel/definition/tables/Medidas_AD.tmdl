	measure 'Encuesta Favorabilidad Variacion MoM' = [Encuesta Favorabilidad] - CALCULATE([Encuesta Favorabilidad], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 07 Comparativos
