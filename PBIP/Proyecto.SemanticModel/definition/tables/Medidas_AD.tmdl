	measure 'Asistencia Registros Sin HC Match' =
			VAR _Total =
			    CALCULATE(
			        [Asistencia Total Registros],
			        REMOVEFILTERS('Dim_ColaboradorHC')
			    )
			VAR _Match =
			    CALCULATE(
			        [Asistencia Registros HC Match],
			        REMOVEFILTERS('Dim_ColaboradorHC')
			    )
			RETURN
			    _Total - _Match
		formatString: #,0
		displayFolder: 08 Headcount HC
		lineageTag: 04f63099-e053-40aa-a2b0-d36dead67715

	measure 'Asistencia Porcentaje HC Match' =
			VAR _Total =
			    CALCULATE(
			        [Asistencia Total Registros],
			        REMOVEFILTERS('Dim_ColaboradorHC')
			    )
			VAR _Match =
			    CALCULATE(
			        [Asistencia Registros HC Match],
			        REMOVEFILTERS('Dim_ColaboradorHC')
			    )
			RETURN
			    DIVIDE(_Match, _Total)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 08 Headcount HC
		lineageTag: 412f9f00-b82b-4f2d-9a8a-7252d1bc77c2

