	measure 'Induccion Porcentaje Cumplimiento' = DIVIDE([Induccion Aprobados], [Induccion Total Colaboradores])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 04 Induccion UC
		lineageTag: e5679ca3-7b9c-4927-8d60-1e2a38d37b4f

	measure 'Induccion Tiempo Promedio Finalizacion Dias' = AVERAGE('Fct_Induccion'[Tiempo_Finalizacion_Dias])
		formatString: #,0.0
		displayFolder: 04 Induccion UC
		lineageTag: 4ecf7285-b950-42c1-b6bc-1382bd7a7848

	measure 'Induccion Cumplimiento Antes UC' = CALCULATE([Induccion Porcentaje Cumplimiento], 'Dim_SegmentoUC'[SegmentoUC_Key] = "Antes_UC")
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 04 Induccion UC
		lineageTag: 2ba24b53-d84d-4e15-963a-370651097629

	measure 'Induccion Cumplimiento UC 2025' = CALCULATE([Induccion Porcentaje Cumplimiento], 'Dim_SegmentoUC'[SegmentoUC_Key] = "UC_2025")
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 04 Induccion UC
		lineageTag: 706a9b2e-4a2f-4dc9-b4f6-a837fd99d2ed

	measure 'Induccion Cumplimiento UC 2026' = CALCULATE([Induccion Porcentaje Cumplimiento], 'Dim_SegmentoUC'[SegmentoUC_Key] = "UC_2026")
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 04 Induccion UC
		lineageTag: f389252f-923d-498e-87d8-4298d4550f77

	measure 'Induccion Variacion UC2025 vs Antes UC' = [Induccion Cumplimiento UC 2025] - [Induccion Cumplimiento Antes UC]
		formatString: 0.0 pp;-0.0 pp;0.0 pp
		displayFolder: 04 Induccion UC
		lineageTag: 9c81cf4a-cd06-468c-affc-34a53cdc1fb7

	measure 'Induccion Variacion UC2026 vs UC2025' = [Induccion Cumplimiento UC 2026] - [Induccion Cumplimiento UC 2025]
		formatString: 0.0 pp;-0.0 pp;0.0 pp
		displayFolder: 04 Induccion UC
		lineageTag: 28128333-0bfc-4b7b-aa96-fd7f89a1e03d

	measure 'KPI Indice Aprendizaje' =
			VAR _Base =
			    {
			        [Plan Porcentaje Ejecucion],
			        [Plan Cobertura Asistencia],
			        [Encuesta Favorabilidad],
			        [Induccion Porcentaje Cumplimiento]
			    }
			RETURN
			    AVERAGEX(FILTER(_Base, NOT ISBLANK([Value])), [Value])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 00 KPIs Gerenciales
		lineageTag: 20367492-6403-4ce2-9065-99d64758cb84

	measure 'KPI Actividades Totales Gestionadas' = [Plan Actividades Planificadas] + [Asistencia Total Registros] + [Encuesta Total Respuestas] + [Induccion Total Colaboradores]
		formatString: #,0
		displayFolder: 00 KPIs Gerenciales
		lineageTag: 436e3d36-7e91-45a6-8731-006381405169

	measure 'Ranking Area Cumplimiento Plan' = RANKX(ALLSELECTED('Dim_Area'[Area]), [Plan Porcentaje Ejecucion], , DESC, Dense)
		formatString: #,0
		displayFolder: 05 Rankings y Alertas
		lineageTag: 7f6aca7f-7192-4d86-8202-b826d0067630

	measure 'Ranking Area Cumplimiento Induccion' = RANKX(ALLSELECTED('Dim_Area'[Area]), [Induccion Porcentaje Cumplimiento], , DESC, Dense)
		formatString: #,0
		displayFolder: 05 Rankings y Alertas
		lineageTag: 838ac55b-68aa-4f9b-890c-5e93178fb5a9

	measure 'Ranking Empresa Asistencia' = RANKX(ALLSELECTED('Dim_Empresa'[Empresa]), [Asistencia Total Asistentes], , DESC, Dense)
		formatString: #,0
		displayFolder: 05 Rankings y Alertas
		lineageTag: b108b9b7-eb2f-4f23-889d-cf61f1f6492f

	measure 'Alerta Plan Bajo Cumplimiento' = IF(NOT ISBLANK([Plan Porcentaje Ejecucion]) && [Plan Porcentaje Ejecucion] < 0.8, 1, 0)
		formatString: #,0
		displayFolder: 05 Rankings y Alertas
		lineageTag: 60c3836c-4cfd-4e27-a23a-dd03110ade43

	measure 'Alerta Induccion Bajo Cumplimiento' = IF(NOT ISBLANK([Induccion Porcentaje Cumplimiento]) && [Induccion Porcentaje Cumplimiento] < 0.9, 1, 0)
		formatString: #,0
		displayFolder: 05 Rankings y Alertas
		lineageTag: a0bf2452-432c-4a18-8ebe-c63f9fd5271d

	measure 'Hallazgo Plan' =
			"Plan: " & FORMAT([Plan Porcentaje Ejecucion], "0.0%") &
			" de ejecucion; brecha de " & FORMAT([Plan Brecha Actividades], "#,0") & " actividades."
		displayFolder: 06 Hallazgos
		lineageTag: c90f3e51-b848-44f7-bfe2-c044e8551ac5

	measure 'Hallazgo Asistencia' =
			"Asistencia: " & FORMAT([Asistencia Total Asistentes], "#,0") &
			" registros y " & FORMAT([% Cobertura], "0.0%") & " de cobertura registrada en el plan."
		displayFolder: 06 Hallazgos
		lineageTag: dd1611ff-cc0b-4c8b-bc5d-2eab245b0df8

	measure 'Hallazgo UC' =
			"UC: Antes " & FORMAT([Induccion Cumplimiento Antes UC], "0.0%") &
			", UC 2025 " & FORMAT([Induccion Cumplimiento UC 2025], "0.0%") &
			", UC 2026 " & FORMAT([Induccion Cumplimiento UC 2026], "0.0%") & "."
		displayFolder: 06 Hallazgos
		lineageTag: 910b7dbd-062d-48a9-8a26-9c7eda604bea

	measure 'Plan Eficacia Promedio' = DIVIDE(AVERAGE('Fct_PlanFormacion'[EFICACIA]), 100)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01 Plan Formacion
		lineageTag: 7c112d7e-9a2c-4aae-925e-fdecb44a6c6a

	measure 'Plan Actividades Pendientes' = [Plan Actividades Vigentes] - [Plan Actividades Ejecutadas]
		formatString: #,0
		displayFolder: 01 Plan Formacion
		lineageTag: 3d4f4796-4656-460c-85ae-281be025cb69

	measure 'Plan Variacion Ejecutadas MoM' = [Plan Actividades Ejecutadas] - CALCULATE([Plan Actividades Ejecutadas], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: #,0
		displayFolder: 07 Comparativos
		lineageTag: cb518286-cff8-4df5-b208-f5f8588f2a32

	measure 'Plan Variacion Ejecutadas MoM %' = DIVIDE([Plan Variacion Ejecutadas MoM], CALCULATE([Plan Actividades Ejecutadas], DATEADD('Dim_Calendario'[Date], -1, MONTH)))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 07 Comparativos
		lineageTag: 85b0fc0f-6973-4584-b043-3938adc6d9a2

	measure 'Plan Variacion Ejecutadas YoY' = [Plan Actividades Ejecutadas] - CALCULATE([Plan Actividades Ejecutadas], SAMEPERIODLASTYEAR('Dim_Calendario'[Date]))
		formatString: #,0
		displayFolder: 07 Comparativos
		lineageTag: 162123aa-1e9e-4298-ae3d-4de7e25f5fc9

	measure 'Plan Variacion Ejecutadas YoY %' = DIVIDE([Plan Variacion Ejecutadas YoY], CALCULATE([Plan Actividades Ejecutadas], SAMEPERIODLASTYEAR('Dim_Calendario'[Date])))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 07 Comparativos
		lineageTag: b47209f7-088c-491e-964e-c4454d69e423

	measure 'Asistencia Variacion MoM' = [Asistencia Total Asistentes] - CALCULATE([Asistencia Total Asistentes], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: #,0
		displayFolder: 07 Comparativos
		lineageTag: 1461ce00-99be-433f-9bfd-fc3828401a21

	measure 'Asistencia Variacion MoM %' = DIVIDE([Asistencia Variacion MoM], CALCULATE([Asistencia Total Asistentes], DATEADD('Dim_Calendario'[Date], -1, MONTH)))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 07 Comparativos
		lineageTag: fcd3c38b-ecb4-480e-b38d-4853b834bc87

	measure 'Asistencia Variacion YoY' = [Asistencia Total Asistentes] - CALCULATE([Asistencia Total Asistentes], SAMEPERIODLASTYEAR('Dim_Calendario'[Date]))
		formatString: #,0
		displayFolder: 07 Comparativos
		lineageTag: 420b2312-0cd1-48a7-8dcd-756f9f52842a

	measure 'Asistencia Variacion YoY %' = DIVIDE([Asistencia Variacion YoY], CALCULATE([Asistencia Total Asistentes], SAMEPERIODLASTYEAR('Dim_Calendario'[Date])))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 07 Comparativos
		lineageTag: 9813eb66-418c-48b0-9710-677970200ba3

	measure 'Induccion Variacion Colaboradores MoM' = [Induccion Total Colaboradores] - CALCULATE([Induccion Total Colaboradores], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: #,0
		displayFolder: 07 Comparativos
		lineageTag: fa88eb05-9b5c-4742-806b-31938463215d

	measure 'Induccion Variacion Colaboradores MoM %' = DIVIDE([Induccion Variacion Colaboradores MoM], CALCULATE([Induccion Total Colaboradores], DATEADD('Dim_Calendario'[Date], -1, MONTH)))
		formatString: 0.0%;-0.0%;0.0%
