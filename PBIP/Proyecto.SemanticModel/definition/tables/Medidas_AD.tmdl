	measure 'HC Recuento Tipo Cargo' = COUNTA('Dim_ColaboradorHC'[Tipo_Cargo])
		formatString: #,0
		displayFolder: 08 Headcount HC
		lineageTag: 9f4f8060-aa3c-4b60-ba1f-ecb70ec5c987

	measure 'HC Porcentaje Tipo Cargo' = DIVIDE([HC Recuento Tipo Cargo], CALCULATE([HC Recuento Tipo Cargo], ALLSELECTED('Dim_ColaboradorHC'[Tipo_Cargo])))
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 08 Headcount HC
