	measure 'HTML Inicio Corporativo Propuesta 2' =
			VAR _FA = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cobertura = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Satisfaccion = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Entrenamiento = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _IndiceAprendizaje = IF(ISBLANK([KPI Indice Aprendizaje]), "-", FORMAT([KPI Indice Aprendizaje], "0.0%"))
			VAR _IndiceDesarrollo = IF(ISBLANK([KPI Indice Desarrollo]), "-", FORMAT([KPI Indice Desarrollo], "0.0%"))
			VAR _FrenteTitulo = SWITCH(_FA, "Desempeño", "Desempe&ntilde;o", "Bienestar y Clima", "Bienestar y Clima", "Desarrollo", "Desarrollo", "Aprendizaje")
			VAR _FrenteEstado = SWITCH(_FA, "Aprendizaje", "Frente activo", "Desarrollo", "En construcci&oacute;n", "Bienestar y Clima", "Frente iniciado", "Desempeño", "Pr&oacute;xima fase", "Frente activo")
			VAR _FrenteDesc = SWITCH(_FA, "Aprendizaje", "Indicadores de formaci&oacute;n, cobertura, satisfacci&oacute;n y entrenamiento.", "Desarrollo", "Seguimiento de PDI, avance, acompa&ntilde;amientos y alertas.", "Bienestar y Clima", "Entrevista de Retiro, clima laboral, eNPS y plan de bienestar.", "Desempeño", "Espacio reservado para evaluaci&oacute;n y seguimiento gerencial.", "Indicadores corporativos del frente seleccionado.")
			VAR _ValorPrincipal = SWITCH(_FA, "Aprendizaje", _IndiceAprendizaje, "Desarrollo", _IndiceDesarrollo, "Bienestar y Clima", "Activo", "Desempeño", "Roadmap", _IndiceAprendizaje)
			VAR _ValorSecundario = SWITCH(_FA, "Aprendizaje", _Entrenamiento, "Desarrollo", _IndiceDesarrollo, "Bienestar y Clima", "Retiro", "Desempeño", "2026", _Entrenamiento)
			RETURN
			"<div style='width:1280px;height:720px;box-sizing:border-box;position:relative;background:#F4F7FB;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:1280px;height:220px;background:linear-gradient(135deg,#000032 0%,#1A3059 54%,#1B487F 100%);color:#ffffff;'>" &
			"<div style='position:absolute;left:42px;top:26px;width:600px;'><div style='font-size:12px;color:#F7931E;letter-spacing:2px;text-transform:uppercase;font-weight:800;'>Grupo LEMCO | People Analytics</div><div style='font-size:35px;line-height:41px;font-weight:850;margin-top:8px;'>Dashboard Corporativo de Desarrollo Organizacional</div><div style='font-size:14px;line-height:20px;color:#dbe6f5;margin-top:12px;width:86%;'>Portada ejecutiva para monitorear frentes de gesti&oacute;n humana con lectura r&aacute;pida, comparaci&oacute;n y priorizaci&oacute;n.</div></div>" &
			"<div style='position:absolute;right:42px;top:34px;width:320px;height:138px;background:rgba(255,255,255,.11);border:1px solid rgba(255,255,255,.25);border-radius:14px;padding:18px;box-sizing:border-box;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>" & _FrenteEstado & "</div><div style='font-size:28px;font-weight:850;margin-top:4px;'>" & _FrenteTitulo & "</div><div style='display:flex;gap:10px;margin-top:18px;'><div style='flex:1;'><div style='font-size:10px;color:#bfd0e4;'>Indicador</div><div style='font-size:22px;font-weight:800;'>" & _ValorPrincipal & "</div></div><div style='flex:1;'><div style='font-size:10px;color:#bfd0e4;'>Estado</div><div style='font-size:22px;font-weight:800;'>" & _ValorSecundario & "</div></div></div></div></div>" &
			"<div style='position:absolute;left:36px;top:136px;width:1212px;height:92px;background:#ffffff;border-radius:14px;box-shadow:0 14px 38px rgba(11,28,53,.16);border:1px solid #DCE5F2;'><div style='position:absolute;left:18px;top:12px;font-size:12px;font-weight:800;color:#1A3059;text-transform:uppercase;letter-spacing:.8px;'>Explorar por</div></div>" &
			"<div style='position:absolute;left:42px;top:256px;width:1210px;height:164px;display:grid;grid-template-columns:1.2fr .8fr .8fr .8fr;gap:16px;'>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:22px;box-shadow:0 8px 24px rgba(11,28,53,.07);'><div style='font-size:13px;color:#F7931E;font-weight:800;'>" & _FrenteTitulo & "</div><div style='font-size:25px;font-weight:850;margin-top:4px;'>" & SWITCH(_FA, "Aprendizaje", "Gesti&oacute;n activa del MVP", "Desarrollo", "Desarrollo en construcci&oacute;n", "Bienestar y Clima", "Escucha y clima iniciado", "Desempeño", "Roadmap de desempe&ntilde;o", "Gesti&oacute;n corporativa") & "</div><div style='font-size:13px;color:#53657D;line-height:18px;margin-top:8px;'>" & _FrenteDesc & "</div><div style='height:7px;background:#E8EEF6;border-radius:8px;margin-top:22px;'><div style='width:" & SWITCH(_FA, "Aprendizaje", "78%", "Desarrollo", "42%", "Bienestar y Clima", "35%", "Desempeño", "18%", "78%") & ";height:7px;background:#F7931E;border-radius:8px;'></div></div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Horas</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Horas & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Formaci&oacute;n planificada y ejecutada.</div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Cobertura</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Cobertura & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Asistencia frente al p&uacute;blico objetivo.</div></div>" &
			"<div style='background:#ffffff;border-radius:14px;border:1px solid #E1E8F2;padding:20px;'><div style='font-size:12px;color:#53657D;'>Satisfacci&oacute;n</div><div style='font-size:34px;font-weight:850;color:#1B487F;'>" & _Satisfaccion & "</div><div style='font-size:12px;color:#53657D;margin-top:8px;'>Favorabilidad de las respuestas.</div></div></div>" &
			"<div style='position:absolute;left:42px;top:448px;width:1210px;height:164px;display:grid;grid-template-columns:repeat(4,1fr);gap:16px;'>" &
			"<div style='background:" & IF(_FA = "Aprendizaje", "#0B1C35", "#ffffff") & ";color:" & IF(_FA = "Aprendizaje", "#ffffff", "#0B1C35") & ";border:" & IF(_FA = "Aprendizaje", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:16px;padding:20px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>" & IF(_FA = "Aprendizaje", "Activo", "MVP") & "</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Aprendizaje</div><div style='font-size:12px;color:" & IF(_FA = "Aprendizaje", "#cbd8e8", "#53657D") & ";line-height:17px;margin-top:8px;'>Entrenamiento neto: " & _Entrenamiento & ".</div></div>" &
			"<div style='background:" & IF(_FA = "Desempeño", "#1A3059", "#ffffff") & ";color:" & IF(_FA = "Desempeño", "#ffffff", "#0B1C35") & ";border:" & IF(_FA = "Desempeño", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:16px;padding:20px;'><div style='font-size:12px;color:" & IF(_FA = "Desempeño", "#F7931E", "#1B487F") & ";font-weight:800;'>Pr&oacute;xima fase</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Desempe&ntilde;o</div><div style='font-size:12px;color:" & IF(_FA = "Desempeño", "#d9e4f2", "#53657D") & ";line-height:17px;margin-top:8px;'>Espacio reservado para evaluaci&oacute;n y seguimiento.</div></div>" &
			"<div style='background:" & IF(_FA = "Desarrollo", "#1B487F", "#ffffff") & ";color:" & IF(_FA = "Desarrollo", "#ffffff", "#0B1C35") & ";border:2px solid #F7931E;border-radius:16px;padding:20px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>En construcci&oacute;n</div><div style='font-size:23px;font-weight:850;margin-top:9px;'>Desarrollo</div><div style='font-size:12px;color:" & IF(_FA = "Desarrollo", "#d9e4f2", "#53657D") & ";line-height:17px;margin-top:8px;'>PDI y acompa&ntilde;amientos en seguimiento.</div></div>" &
			"<div style='background:" & IF(_FA = "Bienestar y Clima", "#1A3059", "#ffffff") & ";color:" & IF(_FA = "Bienestar y Clima", "#ffffff", "#0B1C35") & ";border:" & IF(_FA = "Bienestar y Clima", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:16px;padding:18px;'><div style='font-size:12px;color:#F7931E;font-weight:800;'>Frente iniciado</div><div style='font-size:23px;font-weight:850;margin-top:7px;'>Bienestar y Clima</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:12px;font-size:10px;color:" & IF(_FA = "Bienestar y Clima", "#ffffff", "#1A3059") & ";'><div style='border-left:3px solid #F7931E;background:" & IF(_FA = "Bienestar y Clima", "rgba(255,255,255,.10)", "#F7F9FC") & ";border-radius:7px;padding:7px;'>Entrevista de Retiro</div><div style='background:" & IF(_FA = "Bienestar y Clima", "rgba(255,255,255,.10)", "#F7F9FC") & ";border-radius:7px;padding:7px;'>Planes Clima Laboral</div><div style='background:" & IF(_FA = "Bienestar y Clima", "rgba(255,255,255,.10)", "#F7F9FC") & ";border-radius:7px;padding:7px;'>eNPS Bienestar</div><div style='background:" & IF(_FA = "Bienestar y Clima", "rgba(255,255,255,.10)", "#F7F9FC") & ";border-radius:7px;padding:7px;'>Plan Bienestar</div></div></div></div>" &
			"<div style='position:absolute;left:42px;bottom:26px;width:1210px;height:42px;background:#ffffff;border:1px solid #E1E8F2;border-radius:12px;display:flex;align-items:center;padding:0 18px;box-sizing:border-box;color:#53657D;font-size:12px;'><span style='display:inline-block;width:8px;height:8px;background:#F7931E;border-radius:50%;margin-right:10px;'></span>Lectura sugerida: validar cobertura y satisfacci&oacute;n del frente activo antes de avanzar a focos de gesti&oacute;n.</div></div>"
		displayFolder: 11 HTML Content
		lineageTag: b0132c21-8cd4-4669-8432-92927a52be84

	measure 'HTML Inicio Corporativo Propuesta 3' =
			VAR _FA = SELECTEDVALUE('Dim_Frente_Home'[Frente], "Aprendizaje")
			VAR _Horas = IF(ISBLANK([Plan Horas Formacion]), "-", FORMAT([Plan Horas Formacion], "#,0"))
			VAR _Cobertura = IF(ISBLANK([% Cobertura]), "-", FORMAT([% Cobertura], "0.0%"))
			VAR _Satisfaccion = IF(ISBLANK([Encuesta Favorabilidad]), "-", FORMAT([Encuesta Favorabilidad], "0.0%"))
			VAR _Onboarding = IF(ISBLANK([Induccion Porcentaje Cumplimiento]), "-", FORMAT([Induccion Porcentaje Cumplimiento], "0.0%"))
			VAR _Entrenamiento = IF(ISBLANK([Induccion Porcentaje Entrenamiento Neto]), "-", FORMAT([Induccion Porcentaje Entrenamiento Neto], "0.0%"))
			VAR _PDI = IF(ISBLANK([PDI Total]), "-", FORMAT([PDI Total], "#,0"))
			VAR _AlertasPDI = IF(ISBLANK([PDI Alertas Criticas]), "-", FORMAT([PDI Alertas Criticas], "#,0"))
			VAR _FrenteTitulo = SWITCH(_FA, "Desempeño", "Desempe&ntilde;o", "Bienestar y Clima", "Bienestar y Clima", "Desarrollo", "Desarrollo", "Aprendizaje")
			VAR _FrenteDesc = SWITCH(_FA, "Aprendizaje", "Lectura integrada de formaci&oacute;n, cobertura, satisfacci&oacute;n, onboarding y entrenamiento.", "Desarrollo", "Planes de Desarrollo Individual, avance, acompa&ntilde;amientos y alertas.", "Bienestar y Clima", "Entrevista de Retiro activa, clima laboral, eNPS y plan de bienestar.", "Desempeño", "Evaluaci&oacute;n de desempe&ntilde;o, metas y seguimiento gerencial.", "Lectura integrada del frente seleccionado.")
			VAR _EstadoActual = SWITCH(_FA, "Aprendizaje", "Aprendizaje MVP", "Desarrollo", "Desarrollo en construcci&oacute;n", "Bienestar y Clima", "Bienestar iniciado", "Desempeño", "Desempe&ntilde;o roadmap", "Aprendizaje MVP")
			VAR _FocoTitulo = SWITCH(_FA, "Aprendizaje", "Priorizar brechas del frente activo", "Desarrollo", "Acelerar seguimiento PDI", "Bienestar y Clima", "Escuchar motivos de retiro y clima", "Desempeño", "Preparar modelo de seguimiento", "Priorizar brechas del frente activo")
			VAR _FocoDetalle = SWITCH(_FA, "Aprendizaje", "Entrenamiento neto " & _Entrenamiento & ", cobertura " & _Cobertura & " y satisfacci&oacute;n " & _Satisfaccion & " deben orientar la conversaci&oacute;n gerencial.", "Desarrollo", _PDI & " PDI activos y " & _AlertasPDI & " alertas requieren lectura priorizada por &aacute;rea, motivo y jefe.", "Bienestar y Clima", "La entrevista de retiro debe alimentar oportunidades de mejora, clima laboral, eNPS y plan de bienestar.", "Desempeño", "Este frente se conserva como roadmap para la siguiente fase de medici&oacute;n y seguimiento.", "Revisar indicadores del frente seleccionado.")
			RETURN
			"<div style='width:1280px;height:720px;box-sizing:border-box;position:relative;background:#ffffff;font-family:Outfit,Segoe UI,Arial,sans-serif;color:#0B1C35;overflow:hidden;'>" &
			"<div style='position:absolute;left:0;top:0;width:250px;height:720px;background:#0B1C35;color:#ffffff;padding:32px 24px;box-sizing:border-box;'><div style='font-size:11px;color:#F7931E;letter-spacing:1.7px;text-transform:uppercase;font-weight:800;'>Home estrategico</div><div style='font-size:28px;line-height:32px;font-weight:850;margin-top:12px;'>Mapa de frentes</div><div style='font-size:13px;color:#c8d6e8;line-height:19px;margin-top:16px;'>Una vista madre para navegar la evoluci&oacute;n del Dashboard Corporativo.</div><div style='position:absolute;bottom:34px;left:24px;right:24px;border-top:1px solid rgba(255,255,255,.18);padding-top:18px;font-size:12px;color:#c8d6e8;'>Estado actual<br><span style='color:#F7931E;font-size:20px;font-weight:850;'>" & _EstadoActual & "</span></div></div>" &
			"<div style='position:absolute;left:276px;top:26px;width:956px;height:76px;background:#F7F9FC;border:1px solid #DCE5F2;border-radius:14px;box-sizing:border-box;'><div style='position:absolute;left:20px;top:10px;font-size:12px;font-weight:800;color:#1A3059;text-transform:uppercase;letter-spacing:.8px;'>Filtros para lectura corporativa</div></div>" &
			"<div style='position:absolute;left:276px;top:126px;width:956px;height:168px;display:grid;grid-template-columns:1.15fr 1fr 1fr;gap:16px;'>" &
			"<div style='background:#1A3059;color:#ffffff;border-radius:14px;padding:22px;box-shadow:0 12px 30px rgba(11,28,53,.14);'><div style='font-size:12px;color:#F7931E;font-weight:800;'>" & SWITCH(_FA, "Aprendizaje", "Frente activo", "Desarrollo", "En construcci&oacute;n", "Bienestar y Clima", "Frente iniciado", "Desempeño", "Pr&oacute;xima fase", "Frente activo") & "</div><div style='font-size:30px;font-weight:850;margin-top:6px;'>" & _FrenteTitulo & "</div><div style='font-size:12px;color:#d9e4f2;line-height:18px;margin-top:8px;'>" & _FrenteDesc & "</div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:14px;padding:20px;'><div style='font-size:12px;color:#53657D;'>Horas de formaci&oacute;n</div><div style='font-size:34px;font-weight:850;color:#1B487F;margin-top:8px;'>" & _Horas & "</div><div style='height:5px;background:#F7931E;border-radius:8px;margin-top:18px;width:72%;'></div></div>" &
			"<div style='background:#ffffff;border:1px solid #DCE5F2;border-radius:14px;padding:20px;'><div style='font-size:12px;color:#53657D;'>Cobertura / satisfacci&oacute;n</div><div style='display:flex;gap:20px;margin-top:14px;'><div><div style='font-size:27px;font-weight:850;color:#1B487F;'>" & _Cobertura & "</div><div style='font-size:11px;color:#53657D;'>Cobertura</div></div><div><div style='font-size:27px;font-weight:850;color:#1B487F;'>" & _Satisfaccion & "</div><div style='font-size:11px;color:#53657D;'>Satisfacci&oacute;n</div></div></div></div></div>" &
			"<div style='position:absolute;left:276px;top:320px;width:956px;height:268px;display:grid;grid-template-columns:1.05fr 1fr;gap:18px;'>" &
			"<div style='background:#ffffff;border:1px solid #E1E8F2;border-radius:14px;padding:24px;box-shadow:0 10px 28px rgba(11,28,53,.06);'><div style='font-size:12px;color:#F7931E;text-transform:uppercase;font-weight:800;letter-spacing:1px;'>Ruta corporativa</div><div style='display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px;'>" &
			"<div style='background:" & IF(_FA = "Aprendizaje", "#0B1C35", "#F7F9FC") & ";color:" & IF(_FA = "Aprendizaje", "#ffffff", "#1A3059") & ";border:" & IF(_FA = "Aprendizaje", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;'>Aprendizaje</div><div style='font-size:11px;color:" & IF(_FA = "Aprendizaje", "#cbd8e8", "#53657D") & ";margin-top:7px;'>Activo | " & _Onboarding & " onboarding</div></div>" &
			"<div style='background:" & IF(_FA = "Desempeño", "#1A3059", "#F7F9FC") & ";color:" & IF(_FA = "Desempeño", "#ffffff", "#1A3059") & ";border:" & IF(_FA = "Desempeño", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;'>Desempe&ntilde;o</div><div style='font-size:11px;color:" & IF(_FA = "Desempeño", "#d9e4f2", "#53657D") & ";margin-top:7px;'>Pr&oacute;xima fase</div></div>" &
			"<div style='background:" & IF(_FA = "Desarrollo", "#1B487F", "#FFF7EE") & ";color:" & IF(_FA = "Desarrollo", "#ffffff", "#1A3059") & ";border:2px solid #F7931E;border-radius:12px;padding:18px;'><div style='font-size:20px;font-weight:850;'>Desarrollo</div><div style='font-size:11px;color:" & IF(_FA = "Desarrollo", "#d9e4f2", "#9D5600") & ";margin-top:7px;'>" & _PDI & " PDI | " & _AlertasPDI & " alertas</div></div>" &
			"<div style='background:" & IF(_FA = "Bienestar y Clima", "#1A3059", "#F7F9FC") & ";color:" & IF(_FA = "Bienestar y Clima", "#ffffff", "#1A3059") & ";border:" & IF(_FA = "Bienestar y Clima", "2px solid #F7931E", "1px solid #DCE5F2") & ";border-radius:12px;padding:16px;'><div style='font-size:20px;font-weight:850;'>Bienestar y Clima</div><div style='font-size:11px;color:#F7931E;font-weight:800;margin-top:7px;'>Entrevista de Retiro activa</div><div style='font-size:10px;color:" & IF(_FA = "Bienestar y Clima", "#d9e4f2", "#53657D") & ";line-height:14px;margin-top:8px;'>Planes Clima Laboral &bull; eNPS Bienestar &bull; Plan Bienestar</div></div></div></div>" &
			"<div style='background:#0B1C35;color:#ffffff;border-radius:14px;padding:24px;'><div style='font-size:12px;color:#F7931E;text-transform:uppercase;font-weight:800;letter-spacing:1px;'>Foco ejecutivo</div><div style='font-size:25px;line-height:30px;font-weight:850;margin-top:12px;'>" & _FocoTitulo & "</div><div style='font-size:13px;line-height:19px;color:#d9e4f2;margin-top:12px;'>" & _FocoDetalle & "</div><div style='margin-top:24px;background:#F7931E;color:#0B1C35;border-radius:22px;padding:9px 14px;display:inline-block;font-size:12px;font-weight:850;'>Ir a decisiones del bloque</div></div></div>" &
			"<div style='position:absolute;left:276px;top:616px;width:956px;height:58px;background:#F7F9FC;border:1px solid #DCE5F2;border-radius:14px;display:flex;align-items:center;gap:18px;padding:0 22px;box-sizing:border-box;'><div style='font-size:12px;color:#53657D;'>Escalabilidad futura</div><div style='height:26px;width:1px;background:#DCE5F2;'></div><div style='font-size:12px;color:#1A3059;font-weight:750;'>Los frentes pendientes se mantienen visibles como roadmap para evitar una portada aislada del programa corporativo.</div></div></div>"
		displayFolder: 11 HTML Content
		lineageTag: c9f46c0b-dd6c-4f12-bfec-4558f16abf2f

	measure 'EntrevistaRetiro Total' = COUNTROWS('Fct_EntrevistaRetiro_Unificada')
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: f807b926-f383-42b3-938f-8342e825ccef

	measure 'EntrevistaRetiro Total Validas' = CALCULATE([EntrevistaRetiro Total], 'Fct_EntrevistaRetiro_Unificada'[RegistroValido_Flag] = 1)
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8a939516-4eec-4449-9e88-47861c581f2e

	measure 'EntrevistaRetiro Total No Validas' = CALCULATE([EntrevistaRetiro Total], 'Fct_EntrevistaRetiro_Unificada'[RegistroValido_Flag] = 0)
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 4b22d283-ed26-42b7-87fe-a0dc6dd3b7bd

	measure 'EntrevistaRetiro Porcentaje Validas' = DIVIDE([EntrevistaRetiro Total Validas], [EntrevistaRetiro Total], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 0bbfbc38-cfaa-47ba-8032-b1b0451c79e4

	measure 'EntrevistaRetiro Total Voluntarios' = CALCULATE([EntrevistaRetiro Total Validas], 'Dim_TipoRetiro'[TipoRetiro_Key] = "VOLUNTARIO")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: ce3fc002-75f7-4c88-9fa7-95a9bd46436f

	measure 'EntrevistaRetiro Total Involuntarios' = CALCULATE([EntrevistaRetiro Total Validas], 'Dim_TipoRetiro'[TipoRetiro_Key] = "INVOLUNTARIO")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 46e0a13f-bc98-4df9-a82c-96381f2b72bc

	measure 'EntrevistaRetiro Porcentaje Voluntarios' = DIVIDE([EntrevistaRetiro Total Voluntarios], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 4b8a6985-b643-4ecd-a112-33f8cf286f2a

	measure 'EntrevistaRetiro Porcentaje Involuntarios' = DIVIDE([EntrevistaRetiro Total Involuntarios], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 084eb376-0877-4fda-998a-b71a897fddda

	measure 'EntrevistaRetiro Total Fuentes' = DISTINCTCOUNT('Dim_FuenteEntrevistaRetiro'[FuenteEntrevista_Key])
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 23a34a57-4d5d-4154-bff4-be8b372bf40f

	measure 'EntrevistaRetiro Motivo Principal' =
			VAR _Tabla =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            ALLSELECTED('Dim_MotivoRetiro'[Motivo_Retiro]),
			            "_Total", [EntrevistaRetiro Total Validas]
			        ),
			        [_Total], DESC,
			        'Dim_MotivoRetiro'[Motivo_Retiro], ASC
			    )
			RETURN
			    COALESCE(CONCATENATEX(_Tabla, 'Dim_MotivoRetiro'[Motivo_Retiro], ", "), "Sin datos")
		displayFolder: 13 Entrevista Retiro
		lineageTag: b053a6f4-7ac9-4eb4-a1b8-c6ae55aceb5f

	measure 'EntrevistaRetiro Total Motivos Distintos' = DISTINCTCOUNT('Dim_MotivoRetiro'[MotivoRetiro_Key])
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 2dcd81c3-e651-4b14-9713-3bd0643b5604

	measure 'EntrevistaRetiro Participacion Motivo' = DIVIDE([EntrevistaRetiro Total Validas], CALCULATE([EntrevistaRetiro Total Validas], ALLSELECTED('Dim_MotivoRetiro'[Motivo_Retiro])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 0773a6dd-436f-4de5-9e6a-cc057fb0e1bf

	measure 'EntrevistaRetiro Participacion UnidadNegocio' = DIVIDE([EntrevistaRetiro Total Validas], CALCULATE([EntrevistaRetiro Total Validas], ALLSELECTED('Dim_UnidadNegocioRetiro'[Unidad_Negocio])), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: a8690235-fd4a-4e27-9321-7b0fff4175ea

	measure 'EntrevistaRetiro UnidadNegocio Top' =
			VAR _Tabla =
			    TOPN(
			        1,
			        ADDCOLUMNS(
			            ALLSELECTED('Dim_UnidadNegocioRetiro'[Unidad_Negocio]),
			            "_Total", [EntrevistaRetiro Total Validas]
			        ),
			        [_Total], DESC,
			        'Dim_UnidadNegocioRetiro'[Unidad_Negocio], ASC
			    )
			RETURN
			    COALESCE(CONCATENATEX(_Tabla, 'Dim_UnidadNegocioRetiro'[Unidad_Negocio], ", "), "Sin datos")
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8fe1e468-8ed6-4add-9607-40b353ed2d01

	measure 'EntrevistaRetiro Causas Prevenibles' = CALCULATE([EntrevistaRetiro Total Validas], 'Fct_EntrevistaRetiro_Unificada'[CausaPrevenible_Key] = "SI")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 9ce75590-6ec4-420f-880c-ed7f6f627042

	measure 'EntrevistaRetiro Porcentaje Causas Prevenibles' = DIVIDE([EntrevistaRetiro Causas Prevenibles], [EntrevistaRetiro Total Validas], 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 340abcd8-a6e6-4b5d-9996-b6b70dedbf99

	measure 'EntrevistaRetiro Variacion Mensual' = [EntrevistaRetiro Total Validas] - CALCULATE([EntrevistaRetiro Total Validas], DATEADD('Dim_Calendario'[Date], -1, MONTH))
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 8e8763df-25ca-424c-96c2-a4052a408be1

	measure 'EntrevistaRetiro Variacion Mensual Porcentaje' = DIVIDE([EntrevistaRetiro Variacion Mensual], CALCULATE([EntrevistaRetiro Total Validas], DATEADD('Dim_Calendario'[Date], -1, MONTH)), 0)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 13 Entrevista Retiro
		lineageTag: 6ecb0227-0552-4d0c-85aa-f4e63bb78d9d

	measure 'EntrevistaRetiro Registros Requieren Plan' = CALCULATE([EntrevistaRetiro Total Validas], 'Fct_EntrevistaRetiro_Unificada'[RequierePlanAccion] = "Si")
		formatString: #,0
		displayFolder: 13 Entrevista Retiro
		lineageTag: 2252ede9-0a9f-4428-ba44-f1e21971f379

	measure 'HTML Shell BC01 Entrevista de Retiro' =
			VAR _Html =
				"<div style='font-family:Outfit,Poppins,Segoe UI,Arial,sans-serif;width:1280px;height:720px;background:#F7F9FC;color:#0B1C35;position:relative;overflow:hidden;'>" &
				"<div style='position:absolute;left:0;top:0;width:1280px;height:100px;background:#0B1C35;'></div>" &
				"<div style='position:absolute;left:48px;top:24px;color:#F7931E;font-size:11px;font-weight:850;letter-spacing:2px;text-transform:uppercase;'>DASHBOARD CORPORATIVO - GRUPO LEMCO</div>" &
				"<div style='position:absolute;left:48px;top:48px;color:#FFFFFF;font-size:25px;font-weight:850;line-height:28px;'>Entrevista de Retiro</div>" &
				"<div style='position:absolute;left:48px;top:78px;color:#D8E4F2;font-size:11px;line-height:14px;'>Motivos de salida, oportunidades de mejora y se&ntilde;ales para Gestion Humana.</div>" &
				"<div style='position:absolute;right:48px;top:32px;background:#F7931E;color:#0B1C35;border-radius:18px;padding:8px 16px;font-size:11px;font-weight:850;'>Bloque Bienestar y Clima</div>" &
				"<div style='position:absolute;left:36px;top:108px;width:1208px;height:120px;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:14px;box-shadow:0 4px 12px rgba(11,28,53,0.05);'></div>" &
				"<div style='position:absolute;left:36px;top:108px;width:4px;height:120px;background:#F7931E;border-radius:14px 0 0 14px;'></div>" &
				"<div style='position:absolute;left:32px;top:228px;width:1216px;height:446px;background:#FFFFFF;border:1px solid #E1E8F2;border-radius:10px;'></div>" &
				"<div style='position:absolute;left:32px;top:674px;width:1005px;height:40px;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:9px;'></div>" &
				"</div>"
			RETURN
				_Html
		displayFolder: 11 HTML Content
		lineageTag: 7c2750e7-b88c-412b-ae31-489e5fab52af

	measure 'HTML Shell BC01 Resumen Ejecutivo Bienestar y Clima' =
			VAR _ERet    = IF(ISBLANK([EntrevistaRetiro Total Validas]),                  "-", FORMAT([EntrevistaRetiro Total Validas], "#,0"))
			VAR _EVolPct = IF(ISBLANK([EntrevistaRetiro Porcentaje Voluntarios]),         "-", FORMAT([EntrevistaRetiro Porcentaje Voluntarios], "0.0%"))
			VAR _EPrev   = IF(ISBLANK([EntrevistaRetiro Porcentaje Causas Prevenibles]),  "-", FORMAT([EntrevistaRetiro Porcentaje Causas Prevenibles], "0.0%"))
			VAR _EMotivo = IF(ISBLANK([EntrevistaRetiro Motivo Principal]),               "N/D", [EntrevistaRetiro Motivo Principal])
			VAR _EUnidad = IF(ISBLANK([EntrevistaRetiro UnidadNegocio Top]),              "N/D", [EntrevistaRetiro UnidadNegocio Top])
			VAR _BProg   = IF(ISBLANK([Bienestar Programaciones Registradas Ejecucion]), "-", FORMAT([Bienestar Programaciones Registradas Ejecucion], "#,0"))
			VAR _BEjec   = IF(ISBLANK([Bienestar Ejecutadas]),                           "-", FORMAT([Bienestar Ejecutadas], "#,0"))
			VAR _BCump   = IF(ISBLANK([Bienestar Cumplimiento al Corte %]),              "-", FORMAT([Bienestar Cumplimiento al Corte %], "0.0%"))
			VAR _BAvance = IF(ISBLANK([Bienestar Avance Anual %]),                       "-", FORMAT([Bienestar Avance Anual %], "0.0%"))
			VAR _BPend   = IF(ISBLANK([Bienestar Pendientes Futuros]),                   "-", FORMAT([Bienestar Pendientes Futuros], "#,0"))
			VAR _Html =
				"<div style='font-family:Outfit,Poppins,Segoe UI,Arial,sans-serif;width:1280px;height:720px;background:#F7F9FC;color:#0B1C35;position:relative;overflow:hidden;'>" &
				"<div style='position:absolute;left:0;top:0;width:1280px;height:100px;background:#0B1C35;'></div>" &
				"<div style='position:absolute;left:48px;top:22px;color:#F7931E;font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;'>DASHBOARD CORPORATIVO - GRUPO LEMCO</div>" &
				"<div style='position:absolute;left:48px;top:44px;color:#FFFFFF;font-size:24px;font-weight:800;'>Bienestar y Clima</div>" &
				"<div style='position:absolute;left:48px;top:75px;color:#D8E4F2;font-size:11px;'>Resumen ejecutivo del frente: Entrevista de Retiro y Plan de Bienestar.</div>" &
				"<div style='position:absolute;right:48px;top:32px;background:#F7931E;color:#0B1C35;border-radius:18px;padding:8px 18px;font-size:11px;font-weight:800;'>Frente iniciado</div>" &
				"<div style='position:absolute;left:0;top:100px;width:1280px;height:76px;background:#FFFFFF;border-bottom:1px solid #DCE5F2;'></div>" &
				"<div style='position:absolute;left:32px;top:188px;width:580px;height:268px;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:12px;padding:16px 18px;box-sizing:border-box;'>" &
				"<div style='font-size:11px;color:#F7931E;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;'>Entrevista de Retiro</div>" &
				"<div style='display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-top:10px;'>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:9px 11px;border-left:3px solid #003A70;'><div style='font-size:9px;color:#53657D;'>Entrevistas validas</div><div style='font-size:20px;font-weight:800;color:#0B1C35;margin-top:3px;'>" & _ERet & "</div></div>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:9px 11px;border-left:3px solid #1B487F;'><div style='font-size:9px;color:#53657D;'>Retiros voluntarios</div><div style='font-size:20px;font-weight:800;color:#1B487F;margin-top:3px;'>" & _EVolPct & "</div></div>" &
				"<div style='background:#FFF8F0;border-radius:7px;padding:9px 11px;border-left:3px solid #F7931E;'><div style='font-size:9px;color:#53657D;'>Causas prevenibles</div><div style='font-size:20px;font-weight:800;color:#F7931E;margin-top:3px;'>" & _EPrev & "</div></div>" &
				"</div>" &
				"<div style='display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:7px;'>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:9px 11px;'><div style='font-size:9px;color:#53657D;'>Motivo principal</div><div style='font-size:12px;font-weight:700;color:#0B1C35;margin-top:4px;line-height:14px;'>" & _EMotivo & "</div></div>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:9px 11px;'><div style='font-size:9px;color:#53657D;'>Unidad con mas retiros</div><div style='font-size:12px;font-weight:700;color:#0B1C35;margin-top:4px;line-height:14px;'>" & _EUnidad & "</div></div>" &
				"</div>" &
				"</div>" &
				"<div style='position:absolute;left:644px;top:188px;width:604px;height:268px;background:#FFFFFF;border:1px solid #DCE5F2;border-radius:12px;padding:16px 18px;box-sizing:border-box;'>" &
				"<div style='font-size:11px;color:#F7931E;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;'>Plan de Bienestar</div>" &
				"<div style='display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:10px;'>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:8px 11px;border-left:3px solid #003A70;'><div style='font-size:9px;color:#53657D;'>Programaciones vigentes</div><div style='font-size:18px;font-weight:800;color:#0B1C35;margin-top:3px;'>" & _BProg & "</div></div>" &
				"<div style='background:#F7F9FC;border-radius:7px;padding:8px 11px;border-left:3px solid #1B487F;'><div style='font-size:9px;color:#53657D;'>Actividades ejecutadas</div><div style='font-size:18px;font-weight:800;color:#1B487F;margin-top:3px;'>" & _BEjec & "</div></div>" &
				"<div style='background:#FFF8F0;border-radius:7px;padding:8px 11px;border-left:3px solid #F7931E;'><div style='font-size:9px;color:#53657D;'>Cumplimiento al corte</div><div style='font-size:18px;font-weight:800;color:#F7931E;margin-top:3px;'>" & _BCump & "</div></div>" &
